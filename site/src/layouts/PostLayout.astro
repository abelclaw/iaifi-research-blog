---
import BaseLayout from "./BaseLayout.astro";
import PostMetadata from "../components/PostMetadata.astro";

interface Props {
  title: string;
  authors: string[];
  arxivUrl: string;
  pdfUrl: string;
  theme: string;
  published: Date;
  abstract: string;
  figures: string[];
  concepts: string[];
}

const { title, authors, arxivUrl, pdfUrl, theme, published, abstract, figures, concepts } =
  Astro.props;
---

<BaseLayout title={`${title} | IAIFI Research Blog`}>
  <div class="mb-6">
    <a
      href={import.meta.env.BASE_URL}
      class="text-sm text-gray-500 hover:text-gray-700 transition-colors"
    >
      &larr; Back to Timeline
    </a>
  </div>

  <article data-pagefind-body>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-6" data-pagefind-meta="title">
      {title}
    </h1>

    <PostMetadata
      authors={authors}
      arxivUrl={arxivUrl}
      pdfUrl={pdfUrl}
      published={published}
      abstract={abstract}
      theme={theme}
      concepts={concepts}
      figures={figures}
    />

    <div class="prose prose-lg max-w-none mt-8">
      <slot />
    </div>
  </article>
</BaseLayout>
