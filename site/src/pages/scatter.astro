---
import BaseLayout from "../layouts/BaseLayout.astro";
import scatterData from "../data/scatter-data.json";

const baseUrl = import.meta.env.BASE_URL;
const papers = scatterData.papers.map((p: any) => ({
  ...p,
  url: p.slug ? baseUrl + "posts/" + p.slug : null,
}));
const hasPapers = papers.length > 0;
---

<BaseLayout title="Research Landscape - IAIFI Research Blog">
  <section class="mb-6">
    <h1 class="text-2xl font-bold text-[#212529] mb-2 flex items-center gap-2">
      <span class="w-1 h-5 rounded-full bg-[#663399] inline-block"></span>
      Research Landscape
    </h1>
    <p class="text-gray-600 text-sm mb-1">
      Each paper is encoded as a vector of research concepts (e.g. <em>bayesian inference</em>, <em>equivariant neural networks</em>),
      then projected to 2D so that papers with similar concept profiles land nearby.
      Hover any paper to reveal which others share its concepts (highlighted in purple).
    </p>
    <div class="text-xs text-gray-400 space-y-0.5 mt-1">
      <p><strong class="text-gray-500">UMAP</strong> — preserves both local clusters <em>and</em> the distances between them. The most faithful overall map.</p>
      <p><strong class="text-gray-500">t-SNE</strong> — tight, well-separated clusters. But cluster positions relative to each other are arbitrary — don't read meaning into which cluster is "left" or "right".</p>
      <p><strong class="text-gray-500">PCA</strong> — linear projection. The horizontal axis is roughly the direction of maximum variance across all concept vectors; the vertical axis is the next. Preserves global spread but smears fine-grained clusters.</p>
    </div>
    <p class="text-xs text-gray-400 mt-2">Scroll to zoom · drag to pan · hover to discover related work · click for details</p>
  </section>

  {!hasPapers ? (
    <div class="text-center py-16 text-gray-500 bg-white rounded-lg border border-gray-200">
      <p class="text-lg font-medium mb-2">No papers published yet.</p>
    </div>
  ) : (
    <>
      <!-- Controls -->
      <div class="mb-4 space-y-2">
        <div class="flex flex-wrap items-center gap-3">
          <!-- Layout method -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 font-medium">Layout:</span>
            <button id="btn-method-umap" class="px-3 py-1 text-xs font-medium rounded-full bg-[#663399] text-white" title="Preserves both local clusters and global distances between them">UMAP</button>
            <button id="btn-method-tsne" class="px-3 py-1 text-xs font-medium rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300" title="Good local clusters; global distances not meaningful">t-SNE</button>
            <button id="btn-method-pca" class="px-3 py-1 text-xs font-medium rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300" title="Linear projection of concept vectors; axes = directions of maximum variance">PCA</button>
          </div>
          <span class="text-xs text-gray-400">|</span>
          <!-- Color mode -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 font-medium">Color:</span>
            <button id="btn-color-theme" class="px-3 py-1 text-xs font-medium rounded-full bg-[#663399] text-white">Theme</button>
            <button id="btn-color-year" class="px-3 py-1 text-xs font-medium rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300">Year</button>
            <button id="btn-color-institution" class="px-3 py-1 text-xs font-medium rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300">Institution</button>
          </div>
          <span class="text-xs text-gray-400">|</span>
          <!-- Year filter -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 font-medium">Years:</span>
            <select id="year-from" class="px-2 py-1 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#663399]/30 bg-white"></select>
            <span class="text-xs text-gray-400">–</span>
            <select id="year-to" class="px-2 py-1 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#663399]/30 bg-white"></select>
          </div>
          <span class="text-xs text-gray-400">|</span>
          <!-- Concept search/highlight -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 font-medium">Concept:</span>
            <div class="relative">
              <input
                id="concept-search"
                type="text"
                placeholder="Highlight a concept…"
                class="px-3 py-1 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#663399]/30 focus:border-[#663399] w-44"
              />
              <div id="concept-dropdown" class="absolute left-0 top-full mt-1 w-56 bg-white border border-gray-200 rounded-lg shadow-lg z-50 max-h-40 overflow-y-auto hidden"></div>
            </div>
            <button id="concept-clear" class="hidden text-xs text-gray-400 hover:text-gray-600 px-1">✕</button>
          </div>
        </div>
        <!-- Sub-controls -->
        <div id="sub-controls" class="flex flex-wrap items-center gap-2"></div>
        <!-- Filter summary -->
        <div id="filter-summary" class="hidden text-xs text-gray-500 flex items-center gap-2">
          <span id="filter-label"></span>
          <button id="clear-filters" class="text-[#663399] hover:underline">Clear</button>
        </div>
      </div>

      <!-- Map -->
      <div
        id="scatter-container"
        class="w-full bg-white rounded-lg border border-gray-200 overflow-hidden relative"
        style="height: 600px"
      ></div>

      <!-- Side panel -->
      <div id="scatter-panel" class="hidden fixed top-0 right-0 h-full w-80 bg-white shadow-xl border-l border-gray-200 z-50 overflow-y-auto">
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Paper</h3>
            <button id="sp-close" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
          </div>
          <h2 id="sp-title" class="text-base font-bold text-gray-900 mb-1"></h2>
          <p id="sp-theme" class="text-xs mb-3"></p>
          <div id="sp-body"></div>
        </div>
      </div>

      <!-- Blog post preview -->
      <div id="blog-preview" class="hidden mt-4">
        <button id="blog-toggle" class="w-full flex items-center justify-between px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
          <span class="text-sm font-semibold text-gray-700">Blog Post Preview</span>
          <span id="blog-toggle-icon" class="text-gray-400 text-sm">&#9660;</span>
        </button>
        <div id="blog-content" class="border border-t-0 border-gray-200 rounded-b-lg p-6 bg-white prose prose-sm max-w-none"></div>
      </div>
    </>
  )}
</BaseLayout>

<script>
  import { select } from "d3-selection";
  import { scaleLinear } from "d3-scale";
  import { zoom } from "d3-zoom";
  import type { ZoomBehavior } from "d3-zoom";
  import scatterData from "../data/scatter-data.json";

  interface PaperPoint {
    id: string;
    title: string;
    nick: string | null;
    theme: string;
    a: string[];
    inst: string | null;
    year: number | null;
    slug: string | null;
    url: string | null;
    cc: number;
    pca: [number, number];
    tsne: [number, number];
    umap: [number, number];
  }

  type Method = "umap" | "tsne" | "pca";

  // ── k-means++ ─────────────────────────────────────────────────────────────
  function kMeans(
    points: [number, number][],
    k: number,
    iters = 50
  ): { assignments: number[]; centroids: [number, number][] } {
    const n = points.length;
    if (n === 0 || k >= n) return { assignments: Array(n).fill(0), centroids: points.slice(0, k) };

    // k-means++ seed
    const chosen: number[] = [Math.floor(Math.random() * n)];
    while (chosen.length < k) {
      const dists = points.map((p) =>
        Math.min(
          ...chosen.map((c) => {
            const dx = p[0] - points[c][0], dy = p[1] - points[c][1];
            return dx * dx + dy * dy;
          })
        )
      );
      const total = dists.reduce((a, b) => a + b, 0);
      let r = Math.random() * total;
      let picked = n - 1;
      for (let i = 0; i < n; i++) {
        r -= dists[i];
        if (r <= 0) { picked = i; break; }
      }
      chosen.push(picked);
    }

    let centroids: [number, number][] = chosen.map((i) => [points[i][0], points[i][1]]);
    const assignments = new Array<number>(n).fill(0);

    for (let iter = 0; iter < iters; iter++) {
      let changed = false;
      for (let i = 0; i < n; i++) {
        let best = 0, bestD = Infinity;
        for (let c = 0; c < k; c++) {
          const dx = points[i][0] - centroids[c][0], dy = points[i][1] - centroids[c][1];
          const d = dx * dx + dy * dy;
          if (d < bestD) { bestD = d; best = c; }
        }
        if (assignments[i] !== best) { assignments[i] = best; changed = true; }
      }
      if (!changed) break;
      const sums: [number, number, number][] = Array.from({ length: k }, () => [0, 0, 0]);
      for (let i = 0; i < n; i++) {
        sums[assignments[i]][0] += points[i][0];
        sums[assignments[i]][1] += points[i][1];
        sums[assignments[i]][2]++;
      }
      centroids = sums.map((s, c) => (s[2] > 0 ? [s[0] / s[2], s[1] / s[2]] : centroids[c])) as [number, number][];
    }
    return { assignments, centroids };
  }

  // ── Main ──────────────────────────────────────────────────────────────────
  function init() {
    const container = document.getElementById("scatter-container");
    if (!container) return;

    const { topConcepts, topInstitutions, conceptIndex } = scatterData as any;
    const papers: PaperPoint[] = (scatterData as any).papers.map((p: any) => ({
      ...p,
      url: p.slug ? import.meta.env.BASE_URL + "posts/" + p.slug : null,
    }));
    if (papers.length === 0) return;

    // Per-paper concept sets from index
    const paperConceptSet: Set<string>[] = papers.map(() => new Set<string>());
    for (const [concept, indices] of Object.entries(conceptIndex as Record<string, number[]>)) {
      for (const i of indices) paperConceptSet[i].add(concept);
    }

    const rect = container.getBoundingClientRect();
    const width = rect.width || 800;
    const height = 600;
    const padding = 48;

    const themeColors: Record<string, string> = {
      "Foundational AI": "#3b82f6",
      "Theoretical Physics": "#8b5cf6",
      "Experimental Physics": "#f59e0b",
      Astrophysics: "#10b981",
    };
    const institutionColors: Record<string, string> = {
      MIT: "#a31f34", Harvard: "#a51c30", Northeastern: "#d41b2c",
      Tufts: "#3e8ede", Brandeis: "#003478", "UMass Boston": "#005a8b",
      Brown: "#4e3629", UPRM: "#00703c", "U. Bern": "#e6002e",
      "U. New Hampshire": "#003da5", "U. Minnesota": "#7a0019",
    };

    const years = papers.map((p) => p.year).filter((y): y is number => y !== null);
    const minYear = Math.min(...years);
    const maxYear = Math.max(...years);
    const uniqueYears = [...new Set(years)].sort();
    const yearColorScale = scaleLinear<string>()
      .domain([minYear, (minYear + maxYear) / 2, maxYear])
      .range(["#6366f1", "#06b6d4", "#10b981"]);

    const relatedColor = "#a855f7";
    const onPill = "px-3 py-1 text-xs font-medium rounded-full bg-[#663399] text-white";
    const offPill = "px-3 py-1 text-xs font-medium rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300";

    // State
    let method: Method = "umap";
    let colorMode: "theme" | "year" | "institution" = "theme";
    const activeThemes = new Set(Object.keys(themeColors));
    let activeConceptHighlight: string | null = null;
    let yearFrom = minYear, yearTo = maxYear;

    const minR = 4, maxR = 12;
    const maxCC = Math.max(1, ...papers.map((p) => p.cc));
    function radius(p: PaperPoint) { return minR + (maxR - minR) * (p.cc / maxCC); }

    const idxMap = new Map(papers.map((p, i) => [p, i]));
    function idx(d: PaperPoint) { return idxMap.get(d) ?? -1; }

    function isVisible(p: PaperPoint): boolean {
      if (p.year === null || p.year < yearFrom || p.year > yearTo) return false;
      if (colorMode === "theme" && !activeThemes.has(p.theme)) return false;
      return true;
    }

    function getFill(d: PaperPoint): string {
      if (activeConceptHighlight) {
        return paperConceptSet[idx(d)]?.has(activeConceptHighlight) ? relatedColor : "#e5e7eb";
      }
      if (colorMode === "theme") return themeColors[d.theme] || "#6b7280";
      if (colorMode === "year") return d.year !== null ? yearColorScale(d.year) : "#9ca3af";
      if (colorMode === "institution") return institutionColors[d.inst || ""] || "#94a3b8";
      return "#6b7280";
    }

    function getOpacity(d: PaperPoint): number {
      if (!isVisible(d)) return 0;
      if (activeConceptHighlight) {
        return paperConceptSet[idx(d)]?.has(activeConceptHighlight) ? 0.9 : 0.18;
      }
      return 0.82;
    }

    // Scales — computed per method
    function buildScales(m: Method) {
      const xs = papers.map((p) => p[m][0]), ys = papers.map((p) => p[m][1]);
      const xM = (Math.max(...xs) - Math.min(...xs)) * 0.06;
      const yM = (Math.max(...ys) - Math.min(...ys)) * 0.06;
      return {
        x: scaleLinear().domain([Math.min(...xs) - xM, Math.max(...xs) + xM]).range([padding, width - padding]),
        y: scaleLinear().domain([Math.min(...ys) - yM, Math.max(...ys) + yM]).range([padding, height - padding]),
      };
    }
    let scales = buildScales(method);

    // SVG
    const svg = select(container).append("svg").attr("width", width).attr("height", height).style("cursor", "grab");
    const g = svg.append("g");
    const labelLayer = g.append("g").attr("pointer-events", "none");

    const tooltip = select("body").append("div")
      .attr("class", "absolute hidden bg-gray-900 text-white text-xs px-3 py-2 rounded-lg shadow-lg pointer-events-none z-50 max-w-xs leading-relaxed")
      .style("position", "absolute");

    const zoomBehavior: ZoomBehavior<SVGSVGElement, unknown> = zoom<SVGSVGElement, unknown>()
      .scaleExtent([0.4, 14])
      .on("zoom", (event) => { g.attr("transform", event.transform); });
    svg.call(zoomBehavior);
    svg.on("dblclick.zoom", null);

    // Dots
    const dots = g.selectAll<SVGCircleElement, PaperPoint>("circle")
      .data(papers).join("circle")
      .attr("cx", (d) => scales.x(d[method][0]))
      .attr("cy", (d) => scales.y(d[method][1]))
      .attr("r", (d) => radius(d))
      .attr("fill", (d) => getFill(d))
      .attr("opacity", (d) => getOpacity(d))
      .attr("stroke", "white").attr("stroke-width", 0.5)
      .style("cursor", "pointer")
      .attr("pointer-events", (d) => (isVisible(d) ? "all" : "none"));

    // ── Related-papers hover ───────────────────────────────────────────────
    function getRelatedSet(hi: number): Set<number> {
      const hc = paperConceptSet[hi];
      if (!hc || hc.size === 0) return new Set();
      const related = new Set<number>();
      papers.forEach((p, i) => {
        if (i === hi || !isVisible(p)) return;
        let shared = 0;
        for (const c of hc) {
          if (paperConceptSet[i]?.has(c)) { shared++; if (shared >= 2) break; }
        }
        if (shared >= 2) related.add(i);
      });
      return related;
    }

    dots
      .on("mouseover", (event, d) => {
        const hi = idx(d);
        const rel = getRelatedSet(hi);

        dots
          .attr("opacity", (dd) => {
            if (!isVisible(dd)) return 0;
            if (dd === d) return 1;
            if (rel.has(idx(dd))) return 0.9;
            return 0.07;
          })
          .attr("stroke", (dd) => (dd === d ? "white" : rel.has(idx(dd)) ? relatedColor : "white"))
          .attr("stroke-width", (dd) => (dd === d ? 2 : rel.has(idx(dd)) ? 1.8 : 0.5));

        // Tooltip with concepts
        const concepts = Array.from(paperConceptSet[hi] || []).slice(0, 4);
        const conceptsHtml = concepts.length > 0
          ? `<div style="margin-top:5px;display:flex;flex-wrap:wrap;gap:3px">${concepts
              .map((c) => `<span style="padding:1px 6px;background:rgba(168,85,247,0.25);border:1px solid rgba(168,85,247,0.45);border-radius:999px;font-size:10px;color:#e9d5ff">${c}</span>`)
              .join("")}</div>`
          : "";
        const relInfo = rel.size > 0
          ? `<div style="margin-top:4px;color:#94a3b8;font-size:10px">${rel.size} related paper${rel.size > 1 ? "s" : ""} highlighted</div>`
          : "";
        const auth = d.a.length > 0
          ? `<div style="color:#94a3b8;margin-top:2px">${d.a.slice(0, 3).join(", ")}${d.a.length > 3 ? " et al." : ""}</div>`
          : "";
        const meta = [d.theme, d.year, d.inst].filter(Boolean).join(" · ");
        const nick = d.nick ? `<div style="color:#60a5fa;font-size:10px;font-weight:600;margin-bottom:2px">${d.nick}</div>` : "";

        tooltip
          .html(`${nick}<div style="font-weight:600;line-height:1.3">${d.title}</div>${auth}<div style="color:#94a3b8;font-size:10px;margin-top:2px">${meta}</div>${conceptsHtml}${relInfo}`)
          .classed("hidden", false)
          .style("left", `${event.pageX + 14}px`)
          .style("top", `${event.pageY - 12}px`);
      })
      .on("mousemove", (event) => {
        tooltip.style("left", `${event.pageX + 14}px`).style("top", `${event.pageY - 12}px`);
      })
      .on("mouseout", () => {
        dots.attr("opacity", (d) => getOpacity(d)).attr("stroke", "white").attr("stroke-width", 0.5);
        tooltip.classed("hidden", true);
      })
      .on("click", (_, d) => openPanel(d));

    // ── Cluster labels ─────────────────────────────────────────────────────
    function renderClusterLabels() {
      labelLayer.selectAll("*").remove();
      if (activeConceptHighlight) return; // labels clutter concept mode

      const visible = papers.filter(isVisible);
      if (visible.length < 12) return;

      const K = Math.min(9, Math.floor(visible.length / 14));
      const { assignments, centroids } = kMeans(visible.map((p) => p[method]), K);

      // Count concepts per cluster
      const ccounts: Map<string, number>[] = Array.from({ length: K }, () => new Map());
      visible.forEach((p, vi) => {
        const pi = idx(p);
        for (const concept of (paperConceptSet[pi] || new Set())) {
          ccounts[assignments[vi]].set(concept, (ccounts[assignments[vi]].get(concept) || 0) + 1);
        }
      });

      centroids.forEach((centroid, c) => {
        const clusterSize = assignments.filter((a) => a === c).length;
        if (clusterSize < 5) return;
        const sorted = [...ccounts[c].entries()].sort((a, b) => b[1] - a[1]);
        if (!sorted[0]) return;
        const label = sorted[0][0];
        const scale = 0.85 + Math.min(0.55, clusterSize / 70);
        labelLayer.append("text")
          .attr("x", scales.x(centroid[0]))
          .attr("y", scales.y(centroid[1]))
          .attr("text-anchor", "middle")
          .attr("fill", "rgba(50,50,70,0.16)")
          .attr("font-size", `${12 * scale}px`)
          .attr("font-weight", "700")
          .attr("letter-spacing", "0.07em")
          .attr("pointer-events", "none")
          .text(label.toUpperCase());
      });
    }

    function applyAll() {
      dots
        .attr("fill", (d) => getFill(d))
        .attr("opacity", (d) => getOpacity(d))
        .attr("stroke", "white").attr("stroke-width", 0.5)
        .attr("pointer-events", (d) => (isVisible(d) ? "all" : "none"));
      renderClusterLabels();
      updateSummary();
    }

    // ── Method toggle (UMAP / t-SNE / PCA) ────────────────────────────────
    const methodBtns: [Method, HTMLElement | null][] = [
      ["umap", document.getElementById("btn-method-umap")],
      ["tsne", document.getElementById("btn-method-tsne")],
      ["pca",  document.getElementById("btn-method-pca")],
    ];

    function switchMethod(m: Method) {
      method = m;
      scales = buildScales(m);
      methodBtns.forEach(([k, b]) => { if (b) b.className = k === m ? onPill : offPill; });
      dots
        .transition().duration(600)
        .attr("cx", (d) => scales.x(d[m][0]))
        .attr("cy", (d) => scales.y(d[m][1]));
      // Re-render labels after transition
      setTimeout(() => renderClusterLabels(), 650);
    }
    methodBtns.forEach(([m, b]) => b?.addEventListener("click", () => switchMethod(m)));

    // ── Year selects ───────────────────────────────────────────────────────
    const yearFromSel = document.getElementById("year-from") as HTMLSelectElement;
    const yearToSel = document.getElementById("year-to") as HTMLSelectElement;
    for (const y of uniqueYears) {
      yearFromSel.appendChild(Object.assign(document.createElement("option"), { value: y, textContent: y }));
      yearToSel.appendChild(Object.assign(document.createElement("option"), { value: y, textContent: y }));
    }
    yearToSel.value = String(maxYear);

    yearFromSel.addEventListener("change", () => {
      yearFrom = parseInt(yearFromSel.value);
      if (yearFrom > yearTo) { yearTo = yearFrom; yearToSel.value = yearFromSel.value; }
      applyAll();
    });
    yearToSel.addEventListener("change", () => {
      yearTo = parseInt(yearToSel.value);
      if (yearTo < yearFrom) { yearFrom = yearTo; yearFromSel.value = yearToSel.value; }
      applyAll();
    });

    // ── Concept highlight search ───────────────────────────────────────────
    const conceptSearchEl = document.getElementById("concept-search") as HTMLInputElement;
    const conceptDropdown = document.getElementById("concept-dropdown")!;
    const conceptClearBtn = document.getElementById("concept-clear")!;

    function setConceptHighlight(name: string | null) {
      activeConceptHighlight = name;
      conceptSearchEl.value = name ?? "";
      conceptClearBtn.classList.toggle("hidden", !name);
      applyAll();
    }

    function showConceptDD(filter: string) {
      const list = filter
        ? (topConcepts as any[]).filter((c: any) => c.name.toLowerCase().includes(filter.toLowerCase())).slice(0, 15)
        : (topConcepts as any[]).slice(0, 15);
      conceptDropdown.innerHTML = list.length === 0
        ? '<div class="px-3 py-2 text-xs text-gray-400">No matches</div>'
        : "";
      for (const c of list) {
        const it = document.createElement("button");
        it.className = "w-full text-left px-3 py-1.5 text-xs hover:bg-gray-50 flex justify-between items-center";
        it.innerHTML = `<span>${c.name}</span><span class="text-gray-400">${c.count}</span>`;
        it.onmousedown = (e) => { e.preventDefault(); setConceptHighlight(c.name); conceptDropdown.classList.add("hidden"); };
        conceptDropdown.appendChild(it);
      }
      conceptDropdown.classList.remove("hidden");
    }
    conceptSearchEl.addEventListener("focus", () => showConceptDD(conceptSearchEl.value));
    conceptSearchEl.addEventListener("input", () => { if (!conceptSearchEl.value) setConceptHighlight(null); showConceptDD(conceptSearchEl.value); });
    conceptSearchEl.addEventListener("blur", () => setTimeout(() => conceptDropdown.classList.add("hidden"), 150));
    conceptClearBtn.addEventListener("click", () => setConceptHighlight(null));

    // ── Color mode ─────────────────────────────────────────────────────────
    const colorBtns: [string, HTMLElement | null][] = [
      ["theme", document.getElementById("btn-color-theme")],
      ["year", document.getElementById("btn-color-year")],
      ["institution", document.getElementById("btn-color-institution")],
    ];
    function setColorMode(mode: "theme" | "year" | "institution") {
      colorMode = mode;
      colorBtns.forEach(([k, b]) => { if (b) b.className = k === mode ? onPill : offPill; });
      buildSubControls();
      applyAll();
    }
    colorBtns.forEach(([m, b]) => b?.addEventListener("click", () => setColorMode(m as any)));

    // ── Sub-controls ───────────────────────────────────────────────────────
    const subControls = document.getElementById("sub-controls")!;
    const filterSummaryEl = document.getElementById("filter-summary")!;
    const filterLabelEl = document.getElementById("filter-label")!;

    document.getElementById("clear-filters")!.addEventListener("click", () => {
      yearFrom = minYear; yearTo = maxYear;
      yearFromSel.value = String(minYear); yearToSel.value = String(maxYear);
      setConceptHighlight(null);
      Object.keys(themeColors).forEach((t) => activeThemes.add(t));
      applyAll(); buildSubControls();
    });

    function updateSummary() {
      const visible = papers.filter(isVisible).length;
      const parts: string[] = [];
      if (yearFrom > minYear || yearTo < maxYear) parts.push(`${yearFrom}–${yearTo}`);
      if (activeConceptHighlight) parts.push(`concept: "${activeConceptHighlight}"`);
      if (colorMode === "theme" && activeThemes.size < Object.keys(themeColors).length)
        parts.push(`${activeThemes.size} theme${activeThemes.size > 1 ? "s" : ""}`);
      if (parts.length > 0 || visible < papers.length) {
        filterLabelEl.textContent = `${visible} of ${papers.length} papers${parts.length ? " · " + parts.join(", ") : ""}`;
        filterSummaryEl.classList.remove("hidden");
      } else {
        filterSummaryEl.classList.add("hidden");
      }
    }

    function buildSubControls() {
      subControls.innerHTML = "";
      if (colorMode === "theme") {
        const w = document.createElement("div"); w.className = "flex flex-wrap gap-1";
        for (const [theme, color] of Object.entries(themeColors)) {
          const b = document.createElement("button");
          b.className = "flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border transition-colors";
          b.style.cssText = `border-color:${color};color:${color};background:${color}20;opacity:${activeThemes.has(theme) ? 1 : 0.3}`;
          b.innerHTML = `<span class="w-2 h-2 rounded-full" style="background:${color}"></span>${theme}`;
          b.onclick = () => {
            activeThemes.has(theme) ? activeThemes.delete(theme) : activeThemes.add(theme);
            b.style.opacity = activeThemes.has(theme) ? "1" : "0.3";
            applyAll();
          };
          w.appendChild(b);
        }
        subControls.appendChild(w);
      } else if (colorMode === "year") {
        const w = document.createElement("div"); w.className = "flex items-center gap-2 flex-wrap";
        const bw = document.createElement("div"); bw.className = "flex items-center gap-1";
        ["" + minYear, "", "" + maxYear].forEach((t, i) => {
          if (i === 1) {
            const bar = document.createElement("div");
            bar.className = "rounded-full h-3 w-28";
            bar.style.background = "linear-gradient(to right, #6366f1, #06b6d4, #10b981)";
            bw.appendChild(bar);
          } else {
            const s = document.createElement("span"); s.className = "text-xs text-gray-500"; s.textContent = t;
            bw.appendChild(s);
          }
        });
        w.appendChild(bw);
        const cw = document.createElement("div"); cw.className = "flex flex-wrap gap-1 ml-2";
        for (const y of uniqueYears) {
          const s = document.createElement("span");
          s.className = "px-2 py-0.5 text-xs rounded-full font-medium cursor-pointer hover:opacity-75 transition-opacity";
          const c = yearColorScale(y);
          s.style.cssText = `background:${c}30;color:${c};border:1px solid ${c}50`;
          s.textContent = `${y} (${papers.filter((p) => p.year === y).length})`;
          s.onclick = () => { yearFrom = y; yearTo = y; yearFromSel.value = String(y); yearToSel.value = String(y); applyAll(); };
          cw.appendChild(s);
        }
        w.appendChild(cw); subControls.appendChild(w);
      } else if (colorMode === "institution") {
        const w = document.createElement("div"); w.className = "flex flex-wrap gap-1";
        for (const inst of (topInstitutions || [])) {
          const color = institutionColors[inst.name] || "#94a3b8";
          const b = document.createElement("button");
          b.className = "flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border";
          b.style.cssText = `border-color:${color};color:${color};background:${color}20`;
          b.innerHTML = `<span class="w-2 h-2 rounded-full" style="background:${color}"></span>${inst.name} <span class="opacity-60 text-[10px]">${inst.count}</span>`;
          w.appendChild(b);
        }
        subControls.appendChild(w);
      }
    }

    // ── Side panel ─────────────────────────────────────────────────────────
    const panelEl = document.getElementById("scatter-panel")!;
    const spTitle = document.getElementById("sp-title")!;
    const spTheme = document.getElementById("sp-theme")!;
    const spBody = document.getElementById("sp-body")!;

    function setPanelOpen(open: boolean) {
      if (open) { panelEl.classList.remove("hidden"); document.body.style.marginRight = "20rem"; }
      else { panelEl.classList.add("hidden"); document.body.style.marginRight = ""; }
    }
    document.getElementById("sp-close")!.addEventListener("click", () => setPanelOpen(false));

    function openPanel(d: PaperPoint) {
      spTitle.textContent = d.title;
      spTheme.textContent = d.theme;
      spTheme.style.color = themeColors[d.theme] || "#6b7280";

      const pi = idx(d);
      const concepts = Array.from(paperConceptSet[pi] || []);
      let html = "";
      if (d.nick) html += `<p class="text-xs text-blue-500 font-semibold mb-1">${d.nick}</p>`;
      if (d.a.length > 0) html += `<p class="text-xs text-gray-500 mb-2">${d.a.join(", ")}</p>`;
      html += `<p class="text-xs text-gray-400 mb-1">${d.id}</p>`;
      if (d.year) html += `<p class="text-xs text-gray-400 mb-1">Year: ${d.year}</p>`;
      if (d.inst) html += `<p class="text-xs text-gray-400 mb-3">Institution: ${d.inst}</p>`;

      if (concepts.length > 0) {
        html += '<p class="text-xs text-gray-500 font-medium mb-1">Concepts — click to highlight on map</p>';
        html += '<div class="flex flex-wrap gap-1 mb-3">';
        for (const c of concepts) {
          const isActive = activeConceptHighlight === c;
          html += `<button class="concept-chip text-xs px-2 py-0.5 rounded-full border transition-colors ${
            isActive
              ? "border-[#a855f7] text-[#a855f7] bg-[#a855f720]"
              : "border-gray-200 text-gray-600 hover:border-[#a855f7] hover:text-[#a855f7]"
          }" data-concept="${c}">${c}</button>`;
        }
        html += "</div>";
      }

      html += '<div class="mt-3 pt-3 border-t border-gray-100 space-y-2">';
      if (d.url) html += `<a href="${d.url}" class="block text-sm text-blue-600 hover:text-blue-800 font-medium">Read blog post &rarr;</a>`;
      html += `<a href="https://arxiv.org/abs/${d.id}" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-600 hover:text-gray-800">View on arXiv &nearr;</a>`;
      html += `<a href="https://arxiv.org/pdf/${d.id}" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-600 hover:text-gray-800">Download PDF &nearr;</a>`;
      html += "</div>";

      spBody.innerHTML = html;

      // Concept chips → highlight on map
      spBody.querySelectorAll<HTMLButtonElement>(".concept-chip").forEach((el) => {
        el.addEventListener("click", () => {
          const c = el.dataset.concept!;
          setConceptHighlight(activeConceptHighlight === c ? null : c);
          openPanel(d); // re-render to update chip styles
        });
      });

      setPanelOpen(true);
      showBlogPreview(d);
    }

    // ── Blog preview ────────────────────────────────────────────────────────
    const blogPreview = document.getElementById("blog-preview")!;
    const blogContent = document.getElementById("blog-content")!;
    const blogToggleIcon = document.getElementById("blog-toggle-icon")!;
    let blogExpanded = true;

    document.getElementById("blog-toggle")!.addEventListener("click", () => {
      blogExpanded = !blogExpanded;
      blogContent.style.display = blogExpanded ? "" : "none";
      blogToggleIcon.innerHTML = blogExpanded ? "&#9660;" : "&#9654;";
    });

    async function showBlogPreview(d: PaperPoint) {
      if (!d.slug) { blogPreview.classList.add("hidden"); return; }
      blogPreview.classList.remove("hidden");
      blogContent.innerHTML = '<p class="text-gray-400 text-sm">Loading…</p>';
      try {
        const resp = await fetch(import.meta.env.BASE_URL + "posts/" + d.slug + "/");
        if (!resp.ok) throw new Error();
        const html = await resp.text();
        const doc = new DOMParser().parseFromString(html, "text/html");
        const article = doc.querySelector("article") || doc.querySelector("main") || doc.querySelector(".prose");
        blogContent.innerHTML = article?.innerHTML || '<p class="text-gray-400 text-sm">Could not extract content.</p>';
      } catch {
        blogContent.innerHTML = `<p class="text-gray-400 text-sm">Preview unavailable. <a href="${d.url}" class="text-blue-600 hover:underline">Open full post →</a></p>`;
      }
    }

    // ── Kick off ───────────────────────────────────────────────────────────
    buildSubControls();
    renderClusterLabels();
    updateSummary();
  }

  function safeInit() {
    try { init(); } catch (e: any) {
      console.error("Scatter init error:", e);
      const c = document.getElementById("scatter-container");
      if (c) c.innerHTML = `<div style="padding:2rem;color:red;font-size:14px">Error: ${e.message}</div>`;
    }
  }
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", () => requestAnimationFrame(safeInit));
  else requestAnimationFrame(safeInit);
</script>
