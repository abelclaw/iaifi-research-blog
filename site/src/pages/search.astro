---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search Papers - IAIFI Research Blog">
  <h1 class="text-3xl font-bold text-gray-900 mb-6">Search Papers</h1>

  <p class="text-gray-600 mb-8">
    Search across all published papers by title, authors, or concepts.
  </p>

  <div id="search-container" class="mb-12"></div>

  <link rel="stylesheet" href={`${import.meta.env.BASE_URL}pagefind/pagefind-ui.css`} />
  <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
    window.__pagefindBase = base;
  </script>
  <script is:inline>
    // Load Pagefind UI dynamically with correct base path
    var s = document.createElement("script");
    s.src = (window.__pagefindBase || "/") + "pagefind/pagefind-ui.js";
    s.onload = function() {
      new PagefindUI({
        element: "#search-container",
        showSubResults: true,
        showImages: false,
        baseUrl: window.__pagefindBase || "/",
      });
    };
    document.head.appendChild(s);
  </script>
</BaseLayout>
