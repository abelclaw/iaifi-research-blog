---
import BaseLayout from "../layouts/BaseLayout.astro";
import psData from "../data/paperscape-data.json";

const papers = psData.papers as Array<{
  arxiv_id: string;
  title: string;
  theme: string;
  slug: string | null;
  ps_id: number;
  x: number;
  y: number;
  r: number;
  nc: number;
}>;

const themeColors: Record<string, string> = {
  "Foundational AI": "#3b82f6",
  "Theoretical Physics": "#8b5cf6",
  "Experimental Physics": "#f59e0b",
  "Astrophysics": "#10b981",
};
---

<BaseLayout title="Paperscape - IAIFI Research Blog">
  <section class="mb-4">
    <h1 class="text-2xl font-bold text-[#212529] mb-2 flex items-center gap-2">
      <span class="w-1 h-5 rounded-full bg-[#663399] inline-block"></span>
      Paperscape
    </h1>
    <p class="text-gray-600 text-sm mb-1">
      Explore IAIFI papers on the interactive arXiv Paperscape map.
      Click a paper below to find it on the map, or explore freely.
    </p>
  </section>

  <!-- IAIFI paper browser -->
  <div class="mb-4 space-y-3">
    <div class="flex flex-wrap items-center gap-3">
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500 font-medium">Theme:</span>
        <div id="theme-buttons" class="flex flex-wrap gap-1">
          {Object.entries(themeColors).map(([theme, color]) => (
            <button
              class="theme-btn flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border transition-colors"
              style={`border-color:${color};color:${color};background:${color}20;`}
              data-theme={theme}
            >
              <span class="w-2 h-2 rounded-full" style={`background:${color}`}></span>
              {theme}
            </button>
          ))}
        </div>
      </div>
      <span class="text-xs text-gray-400">|</span>
      <div class="flex items-center gap-2 flex-1 max-w-sm">
        <span class="text-xs text-gray-500 font-medium">Search:</span>
        <input
          id="search-input"
          type="text"
          placeholder="Title, arXiv ID..."
          class="flex-1 px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#663399]/30 focus:border-[#663399]"
        />
      </div>
    </div>

    <!-- Paper chips -->
    <div id="paper-chips" class="flex flex-wrap gap-1.5 max-h-28 overflow-y-auto pr-1">
      {papers.map((p) => (
        <button
          class="paper-chip px-2.5 py-1 rounded-full text-xs border border-gray-200 text-gray-600 hover:border-[#663399] hover:text-[#663399] hover:bg-[#663399]/5 transition-colors truncate max-w-[280px]"
          data-arxiv={p.arxiv_id}
          data-theme={p.theme}
          title={`${p.title} (${p.arxiv_id})`}
        >
          {p.title.length > 45 ? p.title.slice(0, 45) + "..." : p.title}
        </button>
      ))}
    </div>
    <div class="text-xs text-gray-400">
      <span id="paper-count">{papers.length}</span> IAIFI papers.
      Click a chip to locate it on the map.
    </div>
  </div>

  <!-- Paperscape iframe -->
  <div
    id="ps-container"
    class="w-full rounded-lg border border-gray-200 overflow-hidden relative bg-[#1a1a2e]"
    style="height: 650px;"
  >
    <iframe
      id="ps-iframe"
      src="https://paperscape.org/"
      class="w-full h-full border-0"
      allow="fullscreen"
      loading="lazy"
      title="Paperscape - Interactive arXiv map"
    ></iframe>
    <div id="ps-loading" class="absolute inset-0 flex items-center justify-center bg-[#1a1a2e] pointer-events-none transition-opacity duration-500">
      <div class="text-center">
        <div class="inline-block w-8 h-8 border-2 border-white/20 border-t-white/70 rounded-full animate-spin mb-3"></div>
        <p class="text-white/60 text-sm">Loading Paperscape...</p>
      </div>
    </div>
  </div>

  <div class="mt-3 flex items-center justify-between">
    <div class="text-xs text-gray-400">
      Powered by <a href="https://paperscape.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600">Paperscape</a>
      · <a href="https://github.com/paperscape" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600">GitHub</a>
    </div>
    <button
      id="open-external"
      class="text-xs text-[#663399] hover:underline"
    >
      Open in new tab
    </button>
  </div>
</BaseLayout>

<script>
  interface PaperEntry {
    arxiv_id: string;
    title: string;
    theme: string;
    slug: string | null;
  }

  function init() {
    const iframe = document.getElementById("ps-iframe") as HTMLIFrameElement;
    const loading = document.getElementById("ps-loading") as HTMLElement;
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const chipsContainer = document.getElementById("paper-chips") as HTMLElement;
    const paperCountEl = document.getElementById("paper-count") as HTMLElement;
    const openExtBtn = document.getElementById("open-external") as HTMLElement;

    if (!iframe) return;

    // Hide loading spinner when iframe loads
    iframe.addEventListener("load", () => {
      loading.style.opacity = "0";
      setTimeout(() => { loading.style.display = "none"; }, 500);
    });

    // Collect all paper data from chips
    const allChips = Array.from(chipsContainer.querySelectorAll(".paper-chip")) as HTMLElement[];
    const allPapers: PaperEntry[] = allChips.map(chip => ({
      arxiv_id: chip.dataset.arxiv || "",
      title: chip.title || "",
      theme: chip.dataset.theme || "",
      slug: null,
    }));

    // Current iframe search state
    let currentSearch = "";

    function navigateTo(arxivId: string) {
      currentSearch = arxivId;
      iframe.src = `https://paperscape.org/?s=${encodeURIComponent(arxivId)}`;
      // Show loading again
      loading.style.display = "flex";
      loading.style.opacity = "1";
    }

    // Click on paper chip -> navigate iframe
    chipsContainer.addEventListener("click", (e) => {
      const chip = (e.target as HTMLElement).closest(".paper-chip") as HTMLElement;
      if (!chip) return;
      const arxivId = chip.dataset.arxiv;
      if (!arxivId) return;

      // Highlight active chip
      allChips.forEach(c => c.classList.remove("ring-2", "ring-[#663399]", "bg-[#663399]/10"));
      chip.classList.add("ring-2", "ring-[#663399]", "bg-[#663399]/10");

      navigateTo(arxivId);
    });

    // Open external button
    openExtBtn.addEventListener("click", () => {
      const url = currentSearch
        ? `https://paperscape.org/?s=${encodeURIComponent(currentSearch)}`
        : "https://paperscape.org/";
      window.open(url, "_blank");
    });

    // Theme filter buttons
    const activeThemes = new Set(["Foundational AI", "Theoretical Physics", "Experimental Physics", "Astrophysics"]);
    const themeButtons = document.querySelectorAll(".theme-btn") as NodeListOf<HTMLElement>;

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      allChips.forEach((chip, i) => {
        const paper = allPapers[i];
        const themeMatch = activeThemes.has(paper.theme);
        const searchMatch = !query || paper.title.toLowerCase().includes(query) || paper.arxiv_id.includes(query);
        const visible = themeMatch && searchMatch;
        chip.style.display = visible ? "" : "none";
        if (visible) visibleCount++;
      });

      paperCountEl.textContent = String(visibleCount);
    }

    themeButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const theme = btn.dataset.theme!;
        if (activeThemes.has(theme)) {
          activeThemes.delete(theme);
          btn.style.opacity = "0.3";
        } else {
          activeThemes.add(theme);
          btn.style.opacity = "1";
        }
        applyFilters();
      });
    });

    // Search input
    let searchTimeout: number;
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimeout);
      searchTimeout = window.setTimeout(applyFilters, 150);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
