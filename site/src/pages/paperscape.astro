---
import BaseLayout from "../layouts/BaseLayout.astro";
import psData from "../data/paperscape-data.json";

const papers = psData.papers as Array<{
  arxiv_id: string;
  title: string;
  theme: string;
  slug: string | null;
  ps_id: number;
  x: number;
  y: number;
  r: number;
  nc: number;
}>;

const hasPapers = papers.length > 0;
---

<BaseLayout title="Paperscape - IAIFI Research Blog">
  <section class="mb-4">
    <h1 class="text-2xl font-bold text-[#212529] mb-2 flex items-center gap-2">
      <span class="w-1 h-5 rounded-full bg-[#663399] inline-block"></span>
      Paperscape
    </h1>
    <p class="text-gray-600 text-sm mb-1">
      IAIFI papers on the <a href="https://paperscape.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-800">Paperscape</a> map.
      Paperscape arranges all ~2.5 million arXiv papers using an N-body simulation: papers that cite each other are pulled together by gravitational attraction, so nearby papers tend to be on related topics. Each circle is one paper, and its size reflects how many citations it has received. The colored circles are IAIFI publications; the background shows the rest of arXiv.
    </p>
    <p class="text-xs text-gray-400">
      Scroll to zoom, drag to pan. Click any IAIFI paper (colored) for details, or click near any background dot to identify that paper. Use the theme filters or search bar to find specific IAIFI publications.
    </p>
  </section>

  {!hasPapers ? (
    <div class="text-center py-16 text-gray-500 bg-white rounded-lg border border-gray-200">
      <p class="text-lg font-medium mb-2">No papers published yet.</p>
    </div>
  ) : (
    <>
      <!-- Controls -->
      <div class="mb-4 space-y-3">
        <div class="flex flex-wrap items-center gap-3">
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 font-medium">Theme:</span>
            <div id="theme-buttons" class="flex flex-wrap gap-1"></div>
          </div>
          <span class="text-xs text-gray-400">|</span>
          <div class="flex items-center gap-2 flex-1 max-w-sm">
            <span class="text-xs text-gray-500 font-medium">Search:</span>
            <input
              id="search-input"
              type="text"
              placeholder="Title, author, or arXiv ID..."
              class="flex-1 px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#663399]/30 focus:border-[#663399]"
            />
          </div>
        </div>
        <div id="search-results" class="flex flex-wrap gap-1 text-xs"></div>
      </div>

      <!-- Map container -->
      <div
        id="ps-container"
        class="w-full bg-[#1a1a2e] rounded-lg border border-gray-200 overflow-hidden relative"
        style="height: 650px; cursor: grab;"
      >
        <canvas id="ps-canvas" class="absolute inset-0 w-full h-full"></canvas>
        <!-- Zoom controls -->
        <div class="absolute top-3 right-3 flex flex-col gap-1 z-10">
          <button id="zoom-in" class="w-9 h-9 bg-white/90 hover:bg-white rounded-lg shadow text-lg font-bold text-gray-700 hover:text-[#663399] transition-colors flex items-center justify-center" title="Zoom in">+</button>
          <button id="zoom-out" class="w-9 h-9 bg-white/90 hover:bg-white rounded-lg shadow text-lg font-bold text-gray-700 hover:text-[#663399] transition-colors flex items-center justify-center" title="Zoom out">&minus;</button>
          <button id="zoom-reset" class="w-9 h-9 bg-white/90 hover:bg-white rounded-lg shadow text-xs font-bold text-gray-700 hover:text-[#663399] transition-colors flex items-center justify-center mt-1" title="Reset view">&#8634;</button>
        </div>
        <!-- Zoom level indicator -->
        <div id="zoom-level" class="absolute bottom-3 right-3 text-xs text-white/50 z-10"></div>
      </div>

      <!-- Side panel -->
      <div id="paper-panel" class="hidden fixed top-0 right-0 h-full w-80 bg-white shadow-xl border-l border-gray-200 z-50 overflow-y-auto">
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 id="panel-header" class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Paper</h3>
            <button id="close-panel" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
          </div>
          <h2 id="panel-title" class="text-base font-bold text-gray-900 mb-1"></h2>
          <p id="panel-theme" class="text-xs mb-3"></p>
          <div id="panel-body"></div>
        </div>
      </div>

      <div class="mt-3 flex items-center justify-between">
        <div class="text-xs text-gray-400">
          Showing <span id="paper-count" class="font-medium text-gray-600">{papers.length}</span> IAIFI papers
        </div>
        <div class="text-xs text-gray-400">
          Background: <a href="https://paperscape.org" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600">Paperscape</a>
          · <a href="https://github.com/paperscape" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600">GitHub</a>
        </div>
      </div>
    </>
  )}
</BaseLayout>

<script>
  import psData from "../data/paperscape-data.json";

  interface PaperPoint {
    arxiv_id: string;
    title: string;
    theme: string;
    slug: string | null;
    ps_id: number;
    x: number;
    y: number;
    r: number;
    nc: number;
  }

  // arXiv field labels from Paperscape zone data (z=0)
  const fieldLabels = [
    { x: 23525, y: -32174, r: 94074, name: "astrophysics", code: "astro-ph" },
    { x: 3629, y: 24158, r: 97061, name: "condensed matter", code: "cond-mat" },
    { x: -15730, y: 47150, r: 99693, name: "computer science", code: "cs" },
    { x: -16813, y: -27233, r: 77738, name: "high energy experiment", code: "hep-ex" },
    { x: -19972, y: -9949, r: 64238, name: "high energy lattice", code: "hep-lat" },
    { x: -13450, y: -23918, r: 78335, name: "high energy phenomenology", code: "hep-ph" },
    { x: -898, y: -5209, r: 74684, name: "high energy theory", code: "hep-th" },
    { x: -24515, y: 17003, r: 107648, name: "mathematics", code: "math" },
    { x: -3326, y: 9054, r: 89106, name: "mathematical physics", code: "math-ph" },
    { x: -20726, y: -13660, r: 72827, name: "nuclear experiment", code: "nucl-ex" },
    { x: -18579, y: 32293, r: 86505, name: "quantitative biology", code: "q-bio" },
    { x: -27327, y: 32545, r: 77755, name: "quantitative finance", code: "q-fin" },
    { x: 18750, y: 16301, r: 95165, name: "quantum physics", code: "quant-ph" },
    { x: -19048, y: 37523, r: 87167, name: "statistics", code: "stat" },
  ];

  // Paperscape category colors (from their SCSS source)
  const catColors: Record<string, string> = {
    "hep-th": "#8888ff",
    "hep-ph": "#88ff88",
    "hep-ex": "#ffff88",
    "hep-lat": "#b35c33",
    "gr-qc": "#88ffff",
    "astro-ph": "#e38799",
    "cond-mat": "#b38066",
    "quant-ph": "#66b3b3",
    "physics": "#ff8080",
    "math": "#9edb3d",
    "math-ph": "#9edb3d",
    "cs": "#b34d99",
    "q-bio": "#b34d99",
    "q-fin": "#b34d99",
    "stat": "#b34d99",
    "nucl-ex": "#b35c33",
    "nucl-th": "#b35c33",
    "other": "#b3ff4d",
  };

  // Determine arXiv category color for a world position by nearest field center
  function colorForPosition(wx: number, wy: number): string {
    let bestDist = Infinity;
    let bestCode = "other";
    for (const f of fieldLabels) {
      const dx = wx - f.x;
      const dy = wy - f.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < bestDist) {
        bestDist = dist;
        bestCode = f.code;
      }
    }
    return catColors[bestCode] || catColors["other"];
  }

  async function init() {
    const container = document.getElementById("ps-container");
    const canvas = document.getElementById("ps-canvas") as HTMLCanvasElement;
    if (!container || !canvas) return;

    const baseUrl = import.meta.env.BASE_URL;
    const papers: PaperPoint[] = psData.papers as PaperPoint[];
    const storedWorld = psData.world;
    if (papers.length === 0) return;

    // Fetch live world index from Paperscape to get current bounds & zone config
    let world = storedWorld;
    let zoneConfig = { w: 22696, h: 22696, nx: 8, ny: 8 }; // z=6 defaults
    try {
      const resp = await fetch("https://tile1.paperscape.org/world/world_index.json");
      const liveIndex = await resp.json();
      const liveWorld = {
        xmin: liveIndex.xmin,
        ymin: liveIndex.ymin,
        xmax: liveIndex.xmax,
        ymax: liveIndex.ymax,
      };

      // Apply coordinate correction to paper positions if bounds shifted
      const dx = liveWorld.xmin - storedWorld.xmin;
      const dy = liveWorld.ymin - storedWorld.ymin;
      if (dx !== 0 || dy !== 0) {
        console.log(`Paperscape bounds shifted: dx=${dx}, dy=${dy}, correcting paper positions`);
        for (const p of papers) {
          p.x += dx;
          p.y += dy;
        }
      }

      world = liveWorld;

      // Get z=6 zone config
      if (liveIndex.zones) {
        const z6 = liveIndex.zones.find((z: any) => z.nx === 8 && z.ny === 8);
        if (z6) {
          zoneConfig = { w: z6.w, h: z6.h, nx: z6.nx, ny: z6.ny };
          console.log(`Zone config: ${zoneConfig.w}x${zoneConfig.h}, ${zoneConfig.nx}x${zoneConfig.ny}`);
        }
      }
    } catch (e) {
      console.warn("Failed to fetch live Paperscape index, using stored bounds", e);
    }

    // Dimensions
    const rect = container.getBoundingClientRect();
    const W = rect.width || 800;
    const H = rect.height || 650;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + "px";
    canvas.style.height = H + "px";

    const ctx = canvas.getContext("2d")!;
    ctx.scale(dpr, dpr);

    // Theme colors
    const themeColors: Record<string, string> = {
      "Foundational AI": "#3b82f6",
      "Theoretical Physics": "#8b5cf6",
      "Experimental Physics": "#f59e0b",
      "Astrophysics": "#10b981",
    };

    // State
    const activeThemes = new Set(Object.keys(themeColors));
    let searchQuery = "";
    const searchMatches = new Set<string>();
    let hoveredPaper: PaperPoint | null = null;
    let selectedPaper: PaperPoint | null = null;

    // Fit IAIFI paper cluster with padding
    const xs = papers.map((p) => p.x);
    const ys = papers.map((p) => p.y);
    const pxMin = Math.min(...xs) - 8000;
    const pxMax = Math.max(...xs) + 8000;
    const pyMin = Math.min(...ys) - 8000;
    const pyMax = Math.max(...ys) + 8000;

    const scaleX = W / (pxMax - pxMin);
    const scaleY = H / (pyMax - pyMin);
    const initialScale = Math.min(scaleX, scaleY);

    // Camera: pan (translate) + zoom (scale)
    let camX = (pxMin + pxMax) / 2;
    let camY = (pyMin + pyMax) / 2;
    let camScale = initialScale;

    function worldToScreen(wx: number, wy: number): [number, number] {
      return [
        W / 2 + (wx - camX) * camScale,
        H / 2 + (wy - camY) * camScale,
      ];
    }

    function screenToWorld(sx: number, sy: number): [number, number] {
      return [
        camX + (sx - W / 2) / camScale,
        camY + (sy - H / 2) / camScale,
      ];
    }

    // ── Tile system ──
    const tileServers = [
      "https://tile1.paperscape.org",
      "https://tile2.paperscape.org",
      "https://tile3.paperscape.org",
      "https://tile4.paperscape.org",
    ];
    let tileServerIdx = 0;
    function getTileServer() {
      tileServerIdx = (tileServerIdx + 1) % tileServers.length;
      return tileServers[tileServerIdx];
    }

    const tilings = [
      { z: 0, tw: 45392, th: 45392, nx: 4, ny: 4 },
      { z: 1, tw: 22696, th: 22696, nx: 8, ny: 8 },
      { z: 2, tw: 11348, th: 11348, nx: 16, ny: 16 },
      { z: 3, tw: 5674, th: 5674, nx: 32, ny: 32 },
      { z: 4, tw: 2837, th: 2837, nx: 64, ny: 64 },
      { z: 5, tw: 1418, th: 1418, nx: 128, ny: 128 },
      { z: 6, tw: 709, th: 709, nx: 256, ny: 256 },
    ];
    const TILE_PX = 512;

    const tileCache = new Map<string, HTMLImageElement | "loading" | "error">();
    const MAX_TILE_CACHE = 80;

    function getBestTiling() {
      for (let i = tilings.length - 1; i >= 0; i--) {
        if (tilings[i].tw * camScale >= TILE_PX * 0.5) return tilings[i];
      }
      return tilings[0];
    }

    function drawTiles() {
      ctx.fillStyle = "#1a1a2e";
      ctx.fillRect(0, 0, W, H);

      // Evict old tile images to bound memory
      if (tileCache.size > MAX_TILE_CACHE) {
        const keys = Array.from(tileCache.keys());
        const toEvict = keys.slice(0, keys.length - MAX_TILE_CACHE);
        for (const k of toEvict) tileCache.delete(k);
      }

      const zoomRatio = camScale / initialScale;

      const tiling = getBestTiling();
      const [vxMin, vyMin] = screenToWorld(0, 0);
      const [vxMax, vyMax] = screenToWorld(W, H);

      const ixMin = Math.max(1, Math.floor((vxMin - world.xmin) / tiling.tw) + 1);
      const ixMax = Math.min(tiling.nx, Math.ceil((vxMax - world.xmin) / tiling.tw));
      const iyMin = Math.max(1, Math.floor((vyMin - world.ymin) / tiling.th) + 1);
      const iyMax = Math.min(tiling.ny, Math.ceil((vyMax - world.ymin) / tiling.th));

      // Tiles visible at low-mid zoom, fade out as zone circles take over at deep zoom
      if (zoomRatio >= 100) return; // fully replaced by zone circles
      const tileAlpha = zoomRatio < 20 ? 0.35 : 0.35 * Math.max(0, 1 - (zoomRatio - 20) / 80);
      ctx.globalAlpha = tileAlpha;

      for (let ix = ixMin; ix <= ixMax; ix++) {
        for (let iy = iyMin; iy <= iyMax; iy++) {
          const tileKey = `${tiling.z}/${ix}/${iy}`;
          const tileWx = world.xmin + (ix - 1) * tiling.tw;
          const tileWy = world.ymin + (iy - 1) * tiling.th;

          const [sx, sy] = worldToScreen(tileWx, tileWy);
          const sw = tiling.tw * camScale;
          const sh = tiling.th * camScale;

          const cached = tileCache.get(tileKey);
          if (cached instanceof HTMLImageElement) {
            ctx.drawImage(cached, sx, sy, sw, sh);
          } else if (cached !== "loading") {
            tileCache.set(tileKey, "loading");
            const img = new Image();
            img.onload = () => {
              tileCache.set(tileKey, img);
              scheduleRender();
            };
            img.onerror = () => {
              tileCache.set(tileKey, "error");
            };
            img.src = `${getTileServer()}/world/tiles/${tileKey}.png`;
          }
        }
      }

      ctx.globalAlpha = 1.0;
    }

    // ── Field labels ──
    function drawFieldLabels() {
      const zoomRatio = camScale / initialScale;
      // Only show at lower zoom levels (they get too big when zoomed in)
      if (zoomRatio > 4) return;

      for (const f of fieldLabels) {
        const [sx, sy] = worldToScreen(f.x, f.y);
        // Skip if off screen
        if (sx < -200 || sx > W + 200 || sy < -200 || sy > H + 200) continue;

        // Scale font size with zoom, with limits
        const fontSize = Math.max(10, Math.min(28, 14 * Math.pow(zoomRatio, 0.5)));

        // Draw field name
        ctx.font = `bold ${fontSize}px system-ui, sans-serif`;
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillStyle = "rgba(255, 255, 255, 0.25)";
        ctx.fillText(f.name, sx, sy);

        // Draw code below in smaller text
        ctx.font = `${fontSize * 0.65}px system-ui, sans-serif`;
        ctx.fillStyle = "rgba(255, 255, 255, 0.15)";
        ctx.fillText(f.code, sx, sy + fontSize * 0.9);
      }
    }

    // ── Background paper circles (from Paperscape zone API) ──
    interface ZoneLabel { x: number; y: number; r: number; lbl: string; }
    const zoneCache = new Map<string, ZoneLabel[]>();
    const zoneLoading = new Set<string>();
    const ZONE_NX = zoneConfig.nx; // z=6 grid columns
    const ZONE_NY = zoneConfig.ny; // z=6 grid rows
    const ZONE_TW = zoneConfig.w;  // zone tile width (world units, square)
    const ZONE_TH = zoneConfig.h;  // zone tile height (world units, square)
    const ZONE_MIN_ZOOM = 8; // start showing zone papers at 8x zoom
    const ZONE_TILE_SERVERS = [
      "https://tile1.paperscape.org",
      "https://tile2.paperscape.org",
      "https://tile3.paperscape.org",
      "https://tile4.paperscape.org",
    ];
    let zoneTileIdx = 0;

    function fetchZone(ix: number, iy: number) {
      const key = `6/${ix}/${iy}`;
      if (zoneCache.has(key) || zoneLoading.has(key)) return;
      zoneLoading.add(key);

      const cbName = `lz_6_${ix}_${iy}`;
      const server = ZONE_TILE_SERVERS[zoneTileIdx++ % 4];
      const script = document.createElement("script");
      (window as any)[cbName] = (data: any) => {
        script.remove();
        delete (window as any)[cbName];
        zoneLoading.delete(key);
        if (data?.lbls) {
          zoneCache.set(key, data.lbls);
          scheduleRender();
        }
      };
      script.src = `${server}/world/zones/${key}.json`;
      script.onerror = () => {
        script.remove();
        delete (window as any)[cbName];
        zoneLoading.delete(key);
        zoneCache.set(key, []);
      };
      document.head.appendChild(script);
    }

    const MAX_ZONE_CIRCLES = 8000; // cap circles per frame to prevent browser hang
    const MAX_ZONE_TILES = 60;    // cap concurrent zone tiles in cache

    function drawZoneLabels() {
      const zoomRatio = camScale / initialScale;
      if (zoomRatio < ZONE_MIN_ZOOM) return;

      const [vxMin, vyMin] = screenToWorld(0, 0);
      const [vxMax, vyMax] = screenToWorld(W, H);

      const ixMin = Math.max(1, Math.floor((vxMin - world.xmin) / ZONE_TW) + 1);
      const ixMax = Math.min(ZONE_NX, Math.ceil((vxMax - world.xmin) / ZONE_TW));
      const iyMin = Math.max(1, Math.floor((vyMin - world.ymin) / ZONE_TH) + 1);
      const iyMax = Math.min(ZONE_NY, Math.ceil((vyMax - world.ymin) / ZONE_TH));

      // Evict oldest zone tiles when cache is too large
      if (zoneCache.size > MAX_ZONE_TILES) {
        const keys = Array.from(zoneCache.keys());
        const toEvict = keys.slice(0, keys.length - MAX_ZONE_TILES);
        for (const k of toEvict) zoneCache.delete(k);
      }

      // Zone circles fade in: 0 at 8x, full at 20x
      const zoneAlpha = Math.min(1, (zoomRatio - ZONE_MIN_ZOOM) / 12);
      let circleCount = 0;

      ctx.globalAlpha = zoneAlpha * 0.85;

      for (let ix = ixMin; ix <= ixMax; ix++) {
        for (let iy = iyMin; iy <= iyMax; iy++) {
          const key = `6/${ix}/${iy}`;
          const labels = zoneCache.get(key);
          if (!labels) {
            fetchZone(ix, iy);
            continue;
          }

          for (const lbl of labels) {
            if (circleCount >= MAX_ZONE_CIRCLES) break;
            const screenR = lbl.r * camScale;
            if (screenR < 2.5) continue; // skip sub-pixel dots

            const [sx, sy] = worldToScreen(lbl.x, lbl.y);
            if (sx < -50 || sx > W + 50 || sy < -50 || sy > H + 50) continue;

            const drawR = Math.max(2, screenR);

            const color = colorForPosition(lbl.x, lbl.y);
            ctx.fillStyle = color;
            ctx.beginPath();
            ctx.arc(sx, sy, drawR, 0, Math.PI * 2);
            ctx.fill();
            circleCount++;

            // Author labels at deep zoom
            if (screenR > 12) {
              const parts = lbl.lbl.split(",");
              const label = parts.length >= 3
                ? `${parts[2].trim()}${parts[3] ? " " + parts[3].trim() : ""}`
                : parts[0].trim();
              const displayLabel = label.length > 35 ? label.slice(0, 35) + "..." : label;
              const fontSize = Math.max(9, Math.min(14, screenR * 0.5));
              ctx.font = `${fontSize}px system-ui, sans-serif`;
              ctx.textAlign = "center";
              ctx.textBaseline = "top";
              ctx.fillStyle = `rgba(220, 225, 245, ${0.8 * zoneAlpha})`;
              ctx.fillText(displayLabel, sx, sy + drawR + 3);
              ctx.globalAlpha = zoneAlpha * 0.85;
            }
          }
          if (circleCount >= MAX_ZONE_CIRCLES) break;
        }
        if (circleCount >= MAX_ZONE_CIRCLES) break;
      }
      ctx.globalAlpha = 1.0;
    }

    // ── Paper rendering ──
    function isVisible(p: PaperPoint): boolean {
      if (!activeThemes.has(p.theme)) return false;
      if (searchQuery && !searchMatches.has(p.arxiv_id)) return false;
      return true;
    }

    function paperScreenRadius(p: PaperPoint): number {
      const base = Math.max(4, Math.min(16, 4 + p.nc * 0.2));
      return base / Math.pow(camScale / initialScale, 0.3);
    }

    function drawPapers() {
      const time = performance.now();
      const pulsePhase = Math.sin(time / 800) * 0.15 + 0.85;

      for (const p of papers) {
        if (!isVisible(p)) continue;

        const [sx, sy] = worldToScreen(p.x, p.y);
        if (sx < -20 || sx > W + 20 || sy < -20 || sy > H + 20) continue;

        const r = paperScreenRadius(p);
        const color = themeColors[p.theme] || "#6b7280";
        const isHovered = hoveredPaper === p;
        const isSelected = selectedPaper === p;
        const isHighlighted = searchQuery && searchMatches.has(p.arxiv_id);

        // Glow effect
        if (isHovered || isSelected || isHighlighted) {
          ctx.beginPath();
          ctx.arc(sx, sy, r * 2.5, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.globalAlpha = 0.25;
          ctx.fill();
          ctx.globalAlpha = 1;
        }

        // Outer glow ring (pulse)
        ctx.beginPath();
        ctx.arc(sx, sy, r * 1.4, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.globalAlpha = isHovered ? 0.4 : 0.15 * pulsePhase;
        ctx.fill();

        // Main dot
        ctx.globalAlpha = isHovered || isSelected ? 1 : 0.9;
        ctx.beginPath();
        ctx.arc(sx, sy, r, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.fill();

        // White border
        ctx.strokeStyle = isSelected ? "#fff" : "rgba(255,255,255,0.6)";
        ctx.lineWidth = isHovered || isSelected ? 2 : 0.5;
        ctx.stroke();

        ctx.globalAlpha = 1;

        // Labels when zoomed in or hovered
        const zoomRatio = camScale / initialScale;
        if (isHovered || isSelected || (zoomRatio > 3 && r > 5)) {
          const label = p.title.length > 35 ? p.title.slice(0, 35) + "..." : p.title;
          ctx.font = `${isHovered || isSelected ? "bold " : ""}${Math.max(10, Math.min(13, r))}px system-ui, sans-serif`;
          ctx.textAlign = "center";
          ctx.textBaseline = "top";

          const metrics = ctx.measureText(label);
          const lx = sx - metrics.width / 2 - 3;
          const ly = sy + r + 4;
          ctx.fillStyle = "rgba(0,0,0,0.7)";
          ctx.fillRect(lx, ly, metrics.width + 6, 16);
          ctx.fillStyle = "rgba(255,255,255,0.95)";
          ctx.fillText(label, sx, ly + 2);
        }
      }
    }

    // ── Tooltip ──
    const tooltip = document.createElement("div");
    tooltip.className = "fixed hidden bg-gray-900 text-white text-sm px-3 py-2 rounded-lg shadow-lg pointer-events-none z-50 max-w-xs";
    document.body.appendChild(tooltip);

    function showTooltip(p: PaperPoint, mx: number, my: number) {
      tooltip.innerHTML =
        `<strong>${p.title}</strong><br>` +
        `<span style="opacity:0.7;font-size:0.75rem">${p.arxiv_id} · ${p.theme}</span>` +
        (p.nc > 0 ? `<br><span style="opacity:0.5;font-size:0.75rem">${p.nc} concepts</span>` : "");
      tooltip.classList.remove("hidden");
      tooltip.style.left = `${mx + 14}px`;
      tooltip.style.top = `${my - 10}px`;
    }

    function hideTooltip() {
      tooltip.classList.add("hidden");
    }

    // ── Side panel ──
    const panel = document.getElementById("paper-panel")!;
    const panelHeader = document.getElementById("panel-header")!;
    const panelTitle = document.getElementById("panel-title")!;
    const panelTheme = document.getElementById("panel-theme")!;
    const panelBody = document.getElementById("panel-body")!;
    let panelOpen = false;

    function setPanelOpen(open: boolean) {
      panelOpen = open;
      if (open) {
        panel.classList.remove("hidden");
        document.body.style.marginRight = "20rem";
      } else {
        panel.classList.add("hidden");
        document.body.style.marginRight = "";
        selectedPaper = null;
        scheduleRender();
      }
    }

    document.getElementById("close-panel")!.addEventListener("click", () => setPanelOpen(false));

    function openPaperPanel(p: PaperPoint) {
      selectedPaper = p;
      panelHeader.textContent = "Paper Details";
      panelTitle.textContent = p.title;
      panelTheme.textContent = p.theme;
      panelTheme.style.color = themeColors[p.theme] || "#6b7280";

      let html = "";
      html += `<p class="text-xs text-gray-500 mb-2">${p.arxiv_id}</p>`;

      if (p.nc > 0) {
        html += `<p class="text-xs text-gray-400 mb-3">${p.nc} concepts extracted</p>`;
      }

      // Links
      html += '<div class="mt-4 pt-3 border-t border-gray-100 space-y-2">';
      if (p.slug) {
        html += `<a href="${baseUrl}posts/${p.slug}" class="block text-sm text-blue-600 hover:text-blue-800 font-medium">Read blog post &rarr;</a>`;
      }
      html += `<a href="https://arxiv.org/abs/${p.arxiv_id}" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-600 hover:text-gray-800">View on arXiv &nearr;</a>`;
      html += `<a href="https://arxiv.org/pdf/${p.arxiv_id}" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-600 hover:text-gray-800">Download PDF &nearr;</a>`;
      html += `<button class="ps-zoom-to text-sm text-[#663399] hover:text-[#663399]/70 font-medium" data-x="${p.x}" data-y="${p.y}">Zoom to paper &#8982;</button>`;
      html += '</div>';

      // Nearby IAIFI papers
      const nearby = papers
        .filter(q => q !== p && isVisible(q))
        .map(q => ({ paper: q, dist: Math.sqrt((q.x - p.x) ** 2 + (q.y - p.y) ** 2) }))
        .sort((a, b) => a.dist - b.dist)
        .slice(0, 5);

      if (nearby.length > 0) {
        html += '<div class="mt-4 pt-3 border-t border-gray-100">';
        html += '<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Nearby IAIFI Papers</p>';
        for (const n of nearby) {
          const color = themeColors[n.paper.theme] || "#6b7280";
          html += `<div class="mb-2 flex items-start gap-2">`;
          html += `<span class="mt-1.5 w-2 h-2 rounded-full shrink-0" style="background:${color}"></span>`;
          html += `<div><button class="ps-select-paper text-xs font-medium text-gray-700 hover:text-[#663399] text-left" data-id="${n.paper.arxiv_id}">${n.paper.title}</button>`;
          html += `<p class="text-xs text-gray-400">${n.paper.arxiv_id}</p></div></div>`;
        }
        html += '</div>';
      }

      panelBody.innerHTML = html;
      setPanelOpen(true);

      // Bind zoom-to button
      panelBody.querySelectorAll(".ps-zoom-to").forEach(btn => {
        btn.addEventListener("click", () => {
          const x = parseFloat((btn as HTMLElement).dataset.x!);
          const y = parseFloat((btn as HTMLElement).dataset.y!);
          smoothZoomTo(x, y, initialScale * 8);
        });
      });

      // Bind nearby paper selection
      panelBody.querySelectorAll(".ps-select-paper").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = (btn as HTMLElement).dataset.id!;
          const paper = papers.find(pp => pp.arxiv_id === id);
          if (paper) {
            openPaperPanel(paper);
            smoothZoomTo(paper.x, paper.y, Math.max(camScale, initialScale * 4));
          }
        });
      });

      scheduleRender();
    }

    // ── Paperscape API: fetch any paper at a world location ──
    function showApiStatus(msg: string) {
      panelHeader.textContent = "Paperscape";
      panelTitle.textContent = msg;
      panelTheme.textContent = "";
      panelBody.innerHTML = "";
      setPanelOpen(true);
    }

    function fetchPapescapePaper(wx: number, wy: number) {
      showApiStatus("Looking up paper...");

      const rx = Math.round(wx);
      const ry = Math.round(wy);
      const cbName = "__ps_cb";
      const url = `https://paperscape.org/wombat?ml2p%5B%5D=${rx}&ml2p%5B%5D=${ry}&tbl=&callback=${cbName}`;

      (window as any)[cbName] = null;
      const script = document.createElement("script");
      (window as any)[cbName] = (data: any) => {
        script.remove();
        if (!data?.r?.id) {
          showApiStatus("No paper found at this location. Zoom in more to see individual papers.");
          return;
        }
        showApiStatus("Loading paper details...");
        fetchPapescapeMeta(data.r.id);
      };
      script.src = url;
      script.onerror = () => {
        script.remove();
        showApiStatus("Could not reach Paperscape API.");
      };
      document.head.appendChild(script);
    }

    function fetchPapescapeMeta(paperId: number) {
      const url = `https://paperscape.org/wombat?gdata%5B%5D=${paperId}&flags%5B%5D=1&tbl=&callback=__ps_meta`;

      const script = document.createElement("script");
      (window as any).__ps_meta = (data: any) => {
        script.remove();
        if (!data?.r?.papr?.[0]) return;

        const p = data.r.papr[0];
        openExternalPaperPanel({
          id: p.id,
          title: p.titl || "Unknown",
          authors: p.auth || "",
          arxivId: p.arxv || "",
          categories: p.cats || "",
          citations: p.nc || 0,
          references: p.nr || 0,
        });
      };
      script.src = url;
      script.onerror = () => script.remove();
      document.head.appendChild(script);
    }

    interface ExternalPaper {
      id: number;
      title: string;
      authors: string;
      arxivId: string;
      categories: string;
      citations: number;
      references: number;
    }

    function openExternalPaperPanel(p: ExternalPaper) {
      selectedPaper = null;
      panelHeader.textContent = "arXiv Paper";
      panelTitle.textContent = p.title;
      panelTheme.textContent = p.categories.replace(/,/g, " · ");
      panelTheme.style.color = "#6b7280";

      let html = "";
      if (p.authors) {
        html += `<p class="text-xs text-gray-500 mb-2">${p.authors}</p>`;
      }
      if (p.arxivId) {
        html += `<p class="text-xs text-gray-400 mb-1">${p.arxivId}</p>`;
      }
      html += `<p class="text-xs text-gray-400 mb-3">${p.references} references · ${p.citations} citations</p>`;

      html += '<div class="mt-3 pt-3 border-t border-gray-100 space-y-2">';
      if (p.arxivId) {
        html += `<a href="https://arxiv.org/abs/${p.arxivId}" target="_blank" rel="noopener noreferrer" class="block text-sm text-blue-600 hover:text-blue-800 font-medium">View on arXiv &nearr;</a>`;
        html += `<a href="https://arxiv.org/pdf/${p.arxivId}" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-600 hover:text-gray-800">Download PDF &nearr;</a>`;
      }
      html += '</div>';

      // Check if there's a matching IAIFI paper
      const iaifiMatch = papers.find(pp => pp.arxiv_id === p.arxivId);
      if (iaifiMatch) {
        html += '<div class="mt-3 pt-3 border-t border-gray-100">';
        html += `<p class="text-xs text-[#663399] font-semibold mb-1">This is an IAIFI paper!</p>`;
        html += `<button class="ps-select-paper text-sm text-[#663399] hover:text-[#663399]/70 font-medium" data-id="${iaifiMatch.arxiv_id}">View IAIFI details &rarr;</button>`;
        html += '</div>';
      }

      panelBody.innerHTML = html;
      setPanelOpen(true);

      // Bind IAIFI link if present
      panelBody.querySelectorAll(".ps-select-paper").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = (btn as HTMLElement).dataset.id!;
          const paper = papers.find(pp => pp.arxiv_id === id);
          if (paper) openPaperPanel(paper);
        });
      });
    }

    // ── Render loop ──
    let renderScheduled = false;
    let animating = true;

    function scheduleRender() {
      if (!renderScheduled) {
        renderScheduled = true;
        requestAnimationFrame(render);
      }
    }

    function render() {
      renderScheduled = false;
      ctx.clearRect(0, 0, W, H);
      drawTiles();
      drawFieldLabels();
      drawZoneLabels();
      drawPapers();

      // Update zoom indicator
      const zl = document.getElementById("zoom-level");
      if (zl) {
        const ratio = camScale / initialScale;
        zl.textContent = `${ratio.toFixed(1)}x · z${getBestTiling().z}`;
      }

      if (animating) {
        requestAnimationFrame(render);
      }
    }

    setTimeout(() => { animating = false; }, 2000);

    function restartAnimation() {
      if (!animating) {
        animating = true;
        scheduleRender();
        setTimeout(() => { animating = false; }, 800);
      }
    }

    // ── Mouse interaction ──
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let dragCamX = 0;
    let dragCamY = 0;

    function hitTest(mx: number, my: number): PaperPoint | null {
      for (let i = papers.length - 1; i >= 0; i--) {
        const p = papers[i];
        if (!isVisible(p)) continue;
        const [sx, sy] = worldToScreen(p.x, p.y);
        const r = paperScreenRadius(p) + 4;
        const dx = mx - sx;
        const dy = my - sy;
        if (dx * dx + dy * dy <= r * r) return p;
      }
      return null;
    }

    canvas.addEventListener("mousedown", (e) => {
      isDragging = true;
      dragStartX = e.offsetX;
      dragStartY = e.offsetY;
      dragCamX = camX;
      dragCamY = camY;
      canvas.style.cursor = "grabbing";
    });

    canvas.addEventListener("mousemove", (e) => {
      if (isDragging) {
        const dx = e.offsetX - dragStartX;
        const dy = e.offsetY - dragStartY;
        camX = dragCamX - dx / camScale;
        camY = dragCamY - dy / camScale;
        scheduleRender();
        return;
      }

      const hit = hitTest(e.offsetX, e.offsetY);
      if (hit !== hoveredPaper) {
        hoveredPaper = hit;
        if (hit) {
          canvas.style.cursor = "pointer";
          showTooltip(hit, e.clientX, e.clientY);
        } else {
          // Check zone labels for pointer cursor
          const zoneHit = hitTestZone(e.offsetX, e.offsetY);
          canvas.style.cursor = zoneHit ? "pointer" : "grab";
          if (zoneHit) {
            // Show zone label as tooltip
            const parts = zoneHit.lbl.split(",");
            const tipText = parts.slice(0, 2).join(" — ") + (parts[2] ? ` (${parts[2].trim()})` : "");
            tooltip.textContent = tipText;
            tooltip.style.left = `${e.clientX + 14}px`;
            tooltip.style.top = `${e.clientY - 10}px`;
            tooltip.style.display = "block";
          } else {
            hideTooltip();
          }
        }
        scheduleRender();
        restartAnimation();
      } else if (hit) {
        tooltip.style.left = `${e.clientX + 14}px`;
        tooltip.style.top = `${e.clientY - 10}px`;
      }
    });

    canvas.addEventListener("mouseup", () => {
      if (isDragging) {
        isDragging = false;
        canvas.style.cursor = hoveredPaper ? "pointer" : "grab";
      }
    });

    canvas.addEventListener("mouseleave", () => {
      isDragging = false;
      hoveredPaper = null;
      hideTooltip();
      canvas.style.cursor = "grab";
      scheduleRender();
    });

    // Hit test zone labels (background papers)
    function hitTestZone(mx: number, my: number): ZoneLabel | null {
      const zoomRatio = camScale / initialScale;
      if (zoomRatio < ZONE_MIN_ZOOM) return null;

      const [wx, wy] = screenToWorld(mx, my);
      let bestDist = Infinity;
      let bestLabel: ZoneLabel | null = null;

      for (const labels of zoneCache.values()) {
        for (const lbl of labels) {
          const screenR = lbl.r * camScale;
          if (screenR < 3) continue;
          const [sx, sy] = worldToScreen(lbl.x, lbl.y);
          const dx = mx - sx;
          const dy = my - sy;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const hitR = Math.max(screenR, 8) + 4; // generous click target
          if (dist <= hitR && dist < bestDist) {
            bestDist = dist;
            bestLabel = lbl;
          }
        }
      }
      return bestLabel;
    }

    // Click opens side panel — IAIFI paper or query Paperscape for any paper
    canvas.addEventListener("click", (e) => {
      if (Math.abs(e.offsetX - dragStartX) > 5 || Math.abs(e.offsetY - dragStartY) > 5) return;
      const hit = hitTest(e.offsetX, e.offsetY);
      if (hit) {
        openPaperPanel(hit);
        hideTooltip();
        return;
      }

      // Try zone labels (background papers visible when zoomed in)
      const zoneHit = hitTestZone(e.offsetX, e.offsetY);
      if (zoneHit) {
        // Use Paperscape API to get full metadata via ml2p at the label's exact position
        showApiStatus("Loading paper details...");
        fetchPapescapePaper(zoneHit.x, zoneHit.y);
        return;
      }

      // Fall back to API query at click location
      const [wx, wy] = screenToWorld(e.offsetX, e.offsetY);
      fetchPapescapePaper(wx, wy);
    });

    // Zoom with scroll wheel — centers on selected paper if panel is open
    canvas.addEventListener("wheel", (e) => {
      e.preventDefault();
      const zoomFactor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
      const newScale = Math.max(initialScale * 0.05, Math.min(initialScale * 5000, camScale * zoomFactor));

      if (selectedPaper) {
        // Zoom centered on the selected paper
        camScale = newScale;
        camX = selectedPaper.x;
        camY = selectedPaper.y;
      } else {
        // Zoom toward mouse cursor
        const [wx, wy] = screenToWorld(e.offsetX, e.offsetY);
        camScale = newScale;
        camX = wx - (e.offsetX - W / 2) / camScale;
        camY = wy - (e.offsetY - H / 2) / camScale;
      }

      scheduleRender();
      restartAnimation();
    }, { passive: false });

    // Touch support
    let lastTouchDist = 0;

    canvas.addEventListener("touchstart", (e) => {
      if (e.touches.length === 1) {
        isDragging = true;
        dragStartX = e.touches[0].clientX;
        dragStartY = e.touches[0].clientY;
        dragCamX = camX;
        dragCamY = camY;
      } else if (e.touches.length === 2) {
        isDragging = false;
        const dx = e.touches[1].clientX - e.touches[0].clientX;
        const dy = e.touches[1].clientY - e.touches[0].clientY;
        lastTouchDist = Math.sqrt(dx * dx + dy * dy);
      }
      e.preventDefault();
    }, { passive: false });

    canvas.addEventListener("touchmove", (e) => {
      if (e.touches.length === 1 && isDragging) {
        const dx = e.touches[0].clientX - dragStartX;
        const dy = e.touches[0].clientY - dragStartY;
        camX = dragCamX - dx / camScale;
        camY = dragCamY - dy / camScale;
        scheduleRender();
      } else if (e.touches.length === 2) {
        const dx = e.touches[1].clientX - e.touches[0].clientX;
        const dy = e.touches[1].clientY - e.touches[0].clientY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const mid = {
          x: (e.touches[0].clientX + e.touches[1].clientX) / 2,
          y: (e.touches[0].clientY + e.touches[1].clientY) / 2,
        };

        if (lastTouchDist > 0) {
          const zoomFactor = dist / lastTouchDist;
          camScale = Math.max(initialScale * 0.05, Math.min(initialScale * 5000, camScale * zoomFactor));
          if (selectedPaper) {
            camX = selectedPaper.x;
            camY = selectedPaper.y;
          } else {
            const canvasRect = canvas.getBoundingClientRect();
            const mx = mid.x - canvasRect.left;
            const my = mid.y - canvasRect.top;
            const [wx, wy] = screenToWorld(mx, my);
            camX = wx - (mx - W / 2) / camScale;
            camY = wy - (my - H / 2) / camScale;
          }
        }

        lastTouchDist = dist;
        scheduleRender();
        restartAnimation();
      }
      e.preventDefault();
    }, { passive: false });

    canvas.addEventListener("touchend", () => {
      isDragging = false;
      lastTouchDist = 0;
    });

    // ── Theme buttons ──
    const themeBtnContainer = document.getElementById("theme-buttons")!;
    for (const [theme, color] of Object.entries(themeColors)) {
      const btn = document.createElement("button");
      btn.className = "flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border transition-colors";
      btn.style.cssText = `border-color:${color};color:${color};background:${color}20;`;
      btn.innerHTML = `<span class="w-2 h-2 rounded-full" style="background:${color}"></span>${theme}`;
      btn.addEventListener("click", () => {
        if (activeThemes.has(theme)) activeThemes.delete(theme);
        else activeThemes.add(theme);
        btn.style.opacity = activeThemes.has(theme) ? "1" : "0.3";
        applyFilters();
      });
      themeBtnContainer.appendChild(btn);
    }

    // ── Search ──
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const searchResultsEl = document.getElementById("search-results")!;

    const searchIndex = papers.map((p) => ({
      paper: p,
      text: `${p.title} ${p.arxiv_id}`.toLowerCase(),
    }));

    try {
      const scatterData = (await import("../data/scatter-data.json")).default as any;
      for (const sp of (scatterData?.papers || [])) {
        if (sp.a?.length > 0) {
          const entry = searchIndex.find((e) => e.paper.arxiv_id === sp.id);
          if (entry) entry.text += " " + sp.a.join(" ").toLowerCase();
        }
      }
    } catch {}

    function doSearch(query: string) {
      searchQuery = query.trim().toLowerCase();
      searchMatches.clear();

      if (searchQuery.length === 0) {
        searchResultsEl.innerHTML = "";
        applyFilters();
        return;
      }

      const terms = searchQuery.split(/\s+/);
      for (const entry of searchIndex) {
        if (terms.every((t) => entry.text.includes(t))) {
          searchMatches.add(entry.paper.arxiv_id);
        }
      }

      const matchCount = searchMatches.size;
      searchResultsEl.innerHTML =
        matchCount > 0
          ? `<span class="text-gray-500">${matchCount} match${matchCount !== 1 ? "es" : ""}</span>` +
            (matchCount <= 10
              ? Array.from(searchMatches)
                  .map((id) => {
                    const p = papers.find((pp) => pp.arxiv_id === id)!;
                    return `<button class="ps-zoom-btn px-2 py-0.5 rounded-full border border-gray-300 text-gray-600 hover:border-[#663399] hover:text-[#663399]" data-id="${id}">${p.title.slice(0, 40)}${p.title.length > 40 ? "..." : ""}</button>`;
                  })
                  .join("")
              : "")
          : '<span class="text-gray-400">No matches</span>';

      searchResultsEl.querySelectorAll(".ps-zoom-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = (btn as HTMLElement).dataset.id!;
          const p = papers.find((pp) => pp.arxiv_id === id);
          if (p) {
            smoothZoomTo(p.x, p.y, initialScale * 8);
            openPaperPanel(p);
          }
        });
      });

      applyFilters();
    }

    function applyFilters() {
      const visibleCount = papers.filter((p) => isVisible(p)).length;
      document.getElementById("paper-count")!.textContent = String(visibleCount);
      scheduleRender();
      restartAnimation();
    }

    let searchTimeout: number;
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimeout);
      searchTimeout = window.setTimeout(() => doSearch(searchInput.value), 200);
    });

    // ── Smooth zoom animation ──
    function smoothZoomTo(wx: number, wy: number, targetScale: number, duration = 750) {
      const startCamX = camX;
      const startCamY = camY;
      const startScale = camScale;
      const startTime = performance.now();

      function step(now: number) {
        const t = Math.min(1, (now - startTime) / duration);
        const ease = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
        camX = startCamX + (wx - startCamX) * ease;
        camY = startCamY + (wy - startCamY) * ease;
        camScale = startScale + (targetScale - startScale) * ease;
        scheduleRender();
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    // ── Zoom buttons ──
    const zoomInBtn = document.getElementById("zoom-in")!;
    const zoomOutBtn = document.getElementById("zoom-out")!;
    const zoomResetBtn = document.getElementById("zoom-reset")!;
    const initCamX = camX;
    const initCamY = camY;

    function zoomByFactor(factor: number) {
      const newScale = Math.max(initialScale * 0.05, Math.min(initialScale * 5000, camScale * factor));
      camScale = newScale;
      if (selectedPaper) {
        camX = selectedPaper.x;
        camY = selectedPaper.y;
      }
      scheduleRender();
      restartAnimation();
    }

    zoomInBtn.addEventListener("click", () => zoomByFactor(2));
    zoomOutBtn.addEventListener("click", () => zoomByFactor(0.5));
    zoomResetBtn.addEventListener("click", () => {
      smoothZoomTo(initCamX, initCamY, initialScale);
    });

    // ── Initial render ──
    render();
  }

  async function safeInit() {
    try {
      await init();
    } catch (e: any) {
      console.error("Paperscape init error:", e);
      const c = document.getElementById("ps-container");
      if (c) c.innerHTML = `<div style="padding:2rem;color:red;font-size:14px;">Error: ${e.message}</div>`;
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => requestAnimationFrame(safeInit));
  } else {
    requestAnimationFrame(safeInit);
  }
</script>
