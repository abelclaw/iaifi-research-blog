                <div class="flex items-center gap-1">
                  <input id="slider-link-force" type="range" min="0" max="100" value="40" class="w-16 accent-[#663399] h-1" />
                  <span id="val-link-force" class="text-white/50 w-7 text-right font-mono">0.4</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-white/70">Link distance</span>
                <div class="flex items-center gap-1">
