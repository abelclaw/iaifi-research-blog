      </div>

      <!-- Categorized Concept Index -->
      {sortedCategories.length > 0 && (
        <section class="mt-8">
          <h2 class="text-lg font-bold text-[#212529] mb-4 flex items-center gap-2">
            <span class="w-1 h-5 rounded-full bg-[#444] inline-block"></span>
            Concept Index
          </h2>
          <div class="space-y-4">
            {sortedCategories.map((category) => {
              const colors = categoryColorMap[category] || defaultColor;
              const concepts = conceptsByCategory[category];
              return (
                <div>
                  <h3 class="text-sm font-semibold mb-2 flex items-center gap-2" style={`color:${colors.header}`}>
                    <span class="w-2 h-2 rounded-full inline-block" style={`background:${colors.header}`}></span>
                    {category}
                    <span class="text-xs font-normal text-gray-400">({concepts.length})</span>
                  </h3>
                  <div class="flex flex-wrap gap-1.5">
                    {concepts.map((c) => (
                      <button
                        class="concept-tag text-xs px-2.5 py-1 rounded-full border cursor-pointer hover:opacity-80 transition-opacity"
                        style={`background:${colors.bg};border-color:${colors.border};color:${colors.text}`}
                        data-concept={c.name}
                        data-papers={JSON.stringify(c.papers)}
                      >
                        {c.name}
                        <span class="ml-1 opacity-60">{c.count}</span>
                      </button>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}
    </>
  )}
</BaseLayout>

<script>
  import {
    forceSimulation,
    forceLink,
    forceManyBody,
    forceCenter,
    forceCollide,
  } from "d3-force";
  import { select } from "d3-selection";
  import { zoom, zoomIdentity } from "d3-zoom";
  import { drag } from "d3-drag";

  interface PaperNode {
    id: string; type: "paper"; title: string; nickname: string | null; theme: string; concepts: string[];
    authors: string[]; url: string; x?: number; y?: number; fx?: number | null; fy?: number | null;
  }
  interface ConceptNode {
    id: string; type: "concept"; title: string; papers: string[];
    x?: number; y?: number; fx?: number | null; fy?: number | null;
  }
  type GraphNode = PaperNode | ConceptNode;
  interface GraphLink { source: GraphNode | string; target: GraphNode | string; }
  interface PaperLink { source: string; target: string; score: number; }
  interface ConceptIndexEntry { name: string; count: number; papers: string[]; }

  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("network-container");
    if (!container || !container.dataset.graph) return;

    const {
      paperNodes: allPaperNodes, paperLinks: allPaperLinks, conceptIndex,
      conceptToCategory, categoryColorMap,
    } = JSON.parse(container.dataset.graph) as {
      paperNodes: PaperNode[];
      paperLinks: PaperLink[];
      conceptIndex: ConceptIndexEntry[];
      conceptToCategory: Record<string, string>;
      categoryColorMap: Record<string, { bg: string; border: string; text: string; header: string }>;
    };

    if (allPaperNodes.length === 0) return;

    const width = container.clientWidth;
    const height = container.clientHeight;

    const themeColors: Record<string, string> = {
      "Foundational AI": "#3b82f6",
      "Theoretical Physics": "#8b5cf6",
      "Experimental Physics": "#f59e0b",
      Astrophysics: "#10b981",
    };

    // === Lookup maps (built once from full data) ===
    const paperNodeById = new Map(allPaperNodes.map((p) => [p.id, p]));
    const maxLinkScore = Math.max(1, ...allPaperLinks.map((l) => l.score));
    const minR = 6, maxR = 22;

    // These are recomputed whenever minShared changes
    let minSharedThreshold = 3.0;
    let filteredLinks: PaperLink[] = [];
    let paperAdj: Record<string, Set<string>> = {};
    let connectivityScore: Record<string, number> = {};
    let maxScore = 1;
    let centerPaperId = allPaperNodes[0]?.id || "";
    let defaultCenterId = centerPaperId;
    let maxDepth = 3;

    function recomputeAdjacency() {
      filteredLinks = allPaperLinks.filter((l) => l.score >= minSharedThreshold);
      paperAdj = {};
      connectivityScore = {};
      for (const pl of filteredLinks) {
        if (!paperAdj[pl.source]) paperAdj[pl.source] = new Set();
        if (!paperAdj[pl.target]) paperAdj[pl.target] = new Set();
        paperAdj[pl.source].add(pl.target);
        paperAdj[pl.target].add(pl.source);
        connectivityScore[pl.source] = (connectivityScore[pl.source] || 0) + pl.score;
        connectivityScore[pl.target] = (connectivityScore[pl.target] || 0) + pl.score;
      }
      maxScore = Math.max(1, ...Object.values(connectivityScore));
      // Pick most connected paper as default center
      let best = 0;
      let bestId = "";
      for (const [id, s] of Object.entries(connectivityScore)) {
        if (s > best) { best = s; bestId = id; }
      }
      defaultCenterId = bestId || allPaperNodes[0]?.id || "";
    }
    recomputeAdjacency();
    // Default to "Multiscale Normalizing Flows for Gauge Theories" as central hub
    const preferredCenter = "2404.10819";
    centerPaperId = paperNodeById.has(preferredCenter) ? preferredCenter : defaultCenterId;

    function paperRadius(d: PaperNode): number {
      return minR + (maxR - minR) * ((connectivityScore[d.id] || 0) / maxScore);
    }

    function isConnected(a: string, b: string): boolean {
      return a === b || (paperAdj[a]?.has(b) ?? false);
    }

    function bfsNeighborhood(centerId: string, dist: number): Set<string> {
      const visited = new Set<string>([centerId]);
      let frontier = [centerId];
      for (let d = 0; d < dist; d++) {
        const next: string[] = [];
        for (const id of frontier) {
          for (const nb of paperAdj[id] || []) {
            if (!visited.has(nb)) { visited.add(nb); next.push(nb); }
          }
        }
        frontier = next;
      }
      return visited;
    }

    // === SVG setup (created once) ===
    const svg = select(container)
      .append("svg")
      .attr("width", width)
      .attr("height", height)
      .attr("viewBox", `0 0 ${width} ${height}`);
    const g = svg.append("g");

    // Persistent sub-groups for layering
    const linkLayer = g.append("g");
    const nodeLayer = g.append("g");
    const labelLayer = g.append("g");

    // Tooltip
    const tooltip = select("body").append("div")
      .attr("class", "absolute hidden bg-gray-900 text-white text-sm px-3 py-2 rounded-lg shadow-lg pointer-events-none z-50 max-w-xs")
      .style("position", "absolute");

    // === Zoom ===
    let currentZoomTransform = zoomIdentity;
    const zoomBehavior = zoom<SVGSVGElement, unknown>()
      .scaleExtent([0.3, 5])
      .filter((event: any) => !event.shiftKey && !event.button)
      .on("zoom", (event) => {
        currentZoomTransform = event.transform;
        g.attr("transform", rotationAngle
          ? `${currentZoomTransform} rotate(${rotationAngle}, ${width / 2}, ${height / 2})`
          : String(currentZoomTransform));
      });
    svg.call(zoomBehavior as any);
    svg.on("dblclick.zoom", null);

    // === Shift+drag rotation ===
    let rotationAngle = 0;
    let rotStartAngle = 0;
    let rotBaseAngle = 0;
    const svgNode = svg.node()!;
    svgNode.addEventListener("mousedown", (e: MouseEvent) => {
      if (!e.shiftKey) return;
      e.preventDefault();
      const rect = svgNode.getBoundingClientRect();
      const cx = rect.width / 2, cy = rect.height / 2;
      rotStartAngle = Math.atan2(e.clientY - rect.top - cy, e.clientX - rect.left - cx);
      rotBaseAngle = rotationAngle;
      const onMove = (ev: MouseEvent) => {
        const a = Math.atan2(ev.clientY - rect.top - cy, ev.clientX - rect.left - cx);
        rotationAngle = rotBaseAngle + (a - rotStartAngle) * (180 / Math.PI);
        g.attr("transform", `${currentZoomTransform} rotate(${rotationAngle}, ${width / 2}, ${height / 2})`);
      };
      const onUp = () => {
        window.removeEventListener("mousemove", onMove);
        window.removeEventListener("mouseup", onUp);
      };
      window.addEventListener("mousemove", onMove);
      window.addEventListener("mouseup", onUp);
    });

    // === Side panel refs ===
    const panel = document.getElementById("concept-panel")!;
    const panelHeader = document.getElementById("panel-header")!;
    const panelTitle = document.getElementById("panel-title")!;
    const panelTheme = document.getElementById("panel-theme")!;
    const panelBody = document.getElementById("panel-body")!;
    function setPanelOpen(open: boolean) {
      if (open) {
        panel.classList.remove("hidden");
        document.body.style.marginRight = "20rem";
      } else {
        panel.classList.add("hidden");
        document.body.style.marginRight = "";
      }
    }
    document.getElementById("close-panel")!.addEventListener("click", () => setPanelOpen(false));

    // === Theme toggle state ===
    const activeThemes = new Set(Object.keys(themeColors));

    // === Settings panel state ===
    let showLabels = false;
    let showConcepts = false;
    let nodeScale = 1.0;
    let linkOpacity = 0.6;
    let labelSize = 9;
    let centerForceStrength = 0.05;
    let repelStrength = 150;
    let linkForceStrength = 0.4;
    let linkDistance = 60;
    let collisionStrength = 0.7;

    // === Settings panel toggle ===
    const settingsToggle = document.getElementById("settings-toggle")!;
    const settingsPanel = document.getElementById("settings-panel")!;
    settingsToggle.addEventListener("click", () => {
      settingsPanel.classList.toggle("hidden");
      sessionStorage.setItem("graph-settings-open", settingsPanel.classList.contains("hidden") ? "0" : "1");
    });
    if (sessionStorage.getItem("graph-settings-open") === "1") settingsPanel.classList.remove("hidden");

    // Section collapsing
    document.querySelectorAll(".settings-section-toggle").forEach((btn) => {
      btn.addEventListener("click", () => {
        const section = (btn as HTMLElement).dataset.section!;
        const content = document.getElementById(`section-${section}`)!;
        const chevron = btn.querySelector(".section-chevron")!;
        content.classList.toggle("hidden");
        chevron.classList.toggle("rotate-180");
      });
    });

    // === Mutable graph state — rebuilt on every center/depth change ===
    let simulation: ReturnType<typeof forceSimulation> | null = null;
    let currentVisibleIds = new Set<string>();
    let currentApplyThemeFilter: (() => void) | null = null;
    // Track current visible paper data for click/hover handlers
    let visPapers: PaperNode[] = [];
    let visPaperLinks: PaperLink[] = [];
    let visConceptNodes: ConceptNode[] = [];

    function rebuildGraph() {
      // 1. Compute visible set
      currentVisibleIds = bfsNeighborhood(centerPaperId, maxDepth);

      // 2. Filter data to visible subset only
      visPapers = allPaperNodes.filter((p) => currentVisibleIds.has(p.id));
      const visIds = currentVisibleIds;
      // Only show links radiating from the center paper (star topology).
      // At depth > 1 also show links between depth-N and depth-N+1 (tree edges).
      // This avoids the O(n^2) cross-link mess between neighbors.
      // Show all links between visible papers
      visPaperLinks = filteredLinks.filter(
        (l) => visIds.has(l.source) && visIds.has(l.target)
      );

      // Concept nodes that bridge at least 2 visible papers
      const conceptUsage: Record<string, string[]> = {};
      for (const p of visPapers) {
        for (const c of p.concepts) {
          if (!conceptUsage[c]) conceptUsage[c] = [];
          conceptUsage[c].push(p.id);
        }
      }
      const sharedConcepts = Object.entries(conceptUsage)
        .filter(([_, ps]) => ps.length >= 2);
      visConceptNodes = sharedConcepts.map(([name, ps]) => ({
        id: `concept:${name}`, type: "concept" as const, title: name, papers: ps,
      }));
      const visConceptIdSet = new Set(visConceptNodes.map((c) => c.id));

      // Links for force simulation (paper <-> concept)
      const visLinks: GraphLink[] = [];
      for (const [name, ps] of sharedConcepts) {
        for (const pid of ps) {
          visLinks.push({ source: pid, target: `concept:${name}` });
        }
      }

      const allVisNodes: GraphNode[] = [...visPapers, ...visConceptNodes];

      // 3. Stop old simulation
      if (simulation) simulation.stop();

      // 4. Clear SVG layers
      linkLayer.selectAll("*").remove();
      nodeLayer.selectAll("*").remove();
      labelLayer.selectAll("*").remove();

      // 5. Reset positions to center so layout starts fresh
      for (const n of allVisNodes) {
        n.x = width / 2 + (Math.random() - 0.5) * 100;
        n.y = height / 2 + (Math.random() - 0.5) * 100;
        n.fx = null; n.fy = null;
      }

      // 6. Render only visible elements
      const plGroup = linkLayer.selectAll("line").data(visPaperLinks).join("line")
        .attr("stroke", "#94a3b8")
        .attr("stroke-opacity", linkOpacity)
        .attr("stroke-width", (d: PaperLink) => 1 + 4 * (d.score / maxLinkScore))
        .attr("stroke-linecap", "round")
        .attr("cursor", "pointer")
        .on("mouseover", (ev: MouseEvent, d: PaperLink) => {
          select(ev.currentTarget as Element).attr("stroke", "#6366f1").attr("stroke-opacity", 1);
          const srcId = linkId(d.source);
          const tgtId = linkId(d.target);
          const srcP = paperNodeById.get(srcId);
          const tgtP = paperNodeById.get(tgtId);
          const srcName = srcP?.nickname || srcP?.title || srcId;
          const tgtName = tgtP?.nickname || tgtP?.title || tgtId;
          // Compute shared concepts on the fly from paper nodes
          const srcConcepts = new Set(srcP?.concepts || []);
          const shared = (tgtP?.concepts || []).filter((c: string) => srcConcepts.has(c));
          tooltip.html(
            `<strong>${srcName}</strong> — <strong>${tgtName}</strong>` +
            `<br/><span style="opacity:0.6">score: ${d.score.toFixed(1)}</span>` +
            (shared.length > 0 ? `<br/><span style="opacity:0.5">${shared.slice(0, 5).join(", ")}${shared.length > 5 ? " ..." : ""}</span>` : "")
          ).classed("hidden", false);
        })
        .on("mousemove", (ev: MouseEvent) => {
          tooltip.style("left", ev.pageX + 12 + "px").style("top", ev.pageY - 12 + "px");
        })
        .on("mouseout", (ev: MouseEvent) => {
          select(ev.currentTarget as Element).attr("stroke", "#94a3b8").attr("stroke-opacity", linkOpacity);
          tooltip.classed("hidden", true);
        });

      const pGroup = nodeLayer.selectAll("circle").data(visPapers).join("circle")
        .attr("r", (d: PaperNode) => paperRadius(d) * nodeScale)
        .attr("fill", (d: PaperNode) => themeColors[d.theme] || "#6b7280")
        .attr("stroke", (d: PaperNode) => d.id === centerPaperId ? "#663399" : "#fff")
        .attr("stroke-width", (d: PaperNode) => d.id === centerPaperId ? 3 : 2)
        .attr("cursor", "pointer");

      // Paper title labels (shown when showLabels is on)
      const pLabels = labelLayer.selectAll("text.paper-label").data(visPapers).join("text")
        .attr("class", "paper-label")
        .attr("font-size", `${labelSize}px`).attr("fill", "#374151").attr("text-anchor", "start")
        .attr("dx", (d: PaperNode) => paperRadius(d) * nodeScale + 4).attr("dy", 3)
        .attr("pointer-events", "none").attr("opacity", showLabels ? 0.8 : 0)
        .text((d: PaperNode) => d.nickname || (d.title.length > 30 ? d.title.slice(0, 28) + "..." : d.title));

      // Concept bridge dots
      const cDots = nodeLayer.selectAll("circle.concept-dot").data(visConceptNodes).join("circle")
        .attr("class", "concept-dot")
        .attr("r", 3).attr("fill", "#9ca3af").attr("stroke", "#e5e7eb").attr("stroke-width", 1)
        .attr("opacity", showConcepts ? 0.5 : 0)
        .attr("pointer-events", showConcepts ? "all" : "none")
        .attr("cursor", "default")
        .on("mouseover", (ev: MouseEvent, d: ConceptNode) => {
          tooltip.html(
            `<strong>${d.title}</strong><br/><span style="opacity:0.5">${d.papers.length} papers</span>`
          ).classed("hidden", false);
        })
        .on("mousemove", (ev: MouseEvent) => {
          tooltip.style("left", ev.pageX + 12 + "px").style("top", ev.pageY - 12 + "px");
        })
        .on("mouseout", () => { tooltip.classed("hidden", true); });

      const cLabels = labelLayer.selectAll("text.concept-label").data(visConceptNodes).join("text")
        .attr("class", "concept-label")
        .attr("font-size", `${Math.max(7, labelSize - 2)}px`).attr("fill", "#6b7280").attr("text-anchor", "middle")
        .attr("dy", -8).attr("pointer-events", "none").attr("opacity", showConcepts ? 0.6 : 0)
        .text((d: ConceptNode) => d.title);

      // 7. Force simulation on visible subset only
      simulation = forceSimulation<GraphNode>(allVisNodes)
        .force("link", forceLink<GraphNode, GraphLink>(visLinks).id((d) => d.id).distance(linkDistance).strength(linkForceStrength))
        .force("charge", forceManyBody().strength((d: any) =>
          d.type === "paper" ? -repelStrength - 10 * paperRadius(d as PaperNode) * nodeScale : -30
        ).distanceMax(400))
        .force("center", forceCenter(width / 2, height / 2).strength(centerForceStrength))
        .force("collide", forceCollide<GraphNode>((d: any) =>
          d.type === "paper" ? (paperRadius(d as PaperNode) + 4) * nodeScale : 6
        ).strength(collisionStrength));

      const visPaperById = new Map(visPapers.map((p) => [p.id, p]));

      // D3 forceLink replaces source/target string IDs with node object references
      function linkId(end: any): string { return typeof end === "string" ? end : end.id; }

      simulation.on("tick", () => {
        plGroup
          .attr("x1", (d: PaperLink) => visPaperById.get(linkId(d.source))?.x ?? 0)
          .attr("y1", (d: PaperLink) => visPaperById.get(linkId(d.source))?.y ?? 0)
          .attr("x2", (d: PaperLink) => visPaperById.get(linkId(d.target))?.x ?? 0)
          .attr("y2", (d: PaperLink) => visPaperById.get(linkId(d.target))?.y ?? 0);
        pGroup.attr("cx", (d: PaperNode) => d.x!).attr("cy", (d: PaperNode) => d.y!);
        pLabels.attr("x", (d: PaperNode) => d.x!).attr("y", (d: PaperNode) => d.y!);
        cDots.attr("cx", (d: ConceptNode) => d.x!).attr("cy", (d: ConceptNode) => d.y!);
        cLabels.attr("x", (d: ConceptNode) => d.x!).attr("y", (d: ConceptNode) => d.y!);
      });

      // 8. Drag behavior
      let isDragging = false;
      const dragBehavior = drag<SVGCircleElement, PaperNode>()
        .on("start", (event, d) => {
          isDragging = false;
          if (!event.active) simulation!.alphaTarget(0.3).restart();
          d.fx = d.x; d.fy = d.y;
        })
        .on("drag", (event, d) => { isDragging = true; d.fx = event.x; d.fy = event.y; })
        .on("end", (event, d) => {
          if (!event.active) simulation!.alphaTarget(0);
          d.fx = null; d.fy = null;
        });
      pGroup.call(dragBehavior as any);

      // 9. Click: set as new center
      let clickTimer: ReturnType<typeof setTimeout> | null = null;
      pGroup.on("click", (_ev: MouseEvent, d: PaperNode) => {
        if (isDragging) return;
        if (clickTimer) return;
        clickTimer = setTimeout(() => {
          clickTimer = null;
          centerPaperId = d.id;
          rebuildGraph();
          updateCenterLabel();
          openPaperPanel(d);
        }, 250);
      });

      pGroup.on("dblclick", (_ev: MouseEvent, d: PaperNode) => {
        _ev.stopPropagation();
        if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; }
        centerPaperId = d.id;
        rebuildGraph();
        updateCenterLabel();
        // Center viewport after rebuild — find the new node data
        const nd = visPapers.find((p) => p.id === d.id);
        if (nd) openPaperPanel(nd);
      });

      // 10. Hover
      pGroup
        .on("mouseover", (_ev: MouseEvent, d: PaperNode) => {
          const authorPreview = d.authors.length > 0
            ? d.authors.slice(0, 2).join(", ") + (d.authors.length > 2 ? " et al." : "") : "";
          const conceptPreview = d.concepts.length > 0
            ? d.concepts.slice(0, 3).join(", ") + (d.concepts.length > 3 ? " ..." : "") : "";
          tooltip.html(
            `<strong>${d.title}</strong>${authorPreview ? `<br/><span style="opacity:0.7">${authorPreview}</span>` : ""}<br/><span style="opacity:0.5">${d.theme}${conceptPreview ? " · " + conceptPreview : ""}</span>`
          ).classed("hidden", false);

          pGroup.attr("opacity", (o: PaperNode) => isConnected(d.id, o.id) ? 1 : 0.15);
          pLabels.attr("opacity", (o: PaperNode) => isConnected(d.id, o.id) && showLabels ? 0.8 : 0);
          cDots.attr("opacity", (o: ConceptNode) => isConnected(d.id, o.id) ? 0.7 : 0.1);
          cLabels.attr("opacity", (o: ConceptNode) => isConnected(d.id, o.id) ? 1 : 0);
          plGroup.attr("stroke-opacity", (pl: PaperLink) =>
            linkId(pl.source) === d.id || linkId(pl.target) === d.id ? 0.8 : 0.05);
        })
        .on("mousemove", (ev: MouseEvent) => {
          tooltip.style("left", ev.pageX + 12 + "px").style("top", ev.pageY - 12 + "px");
        })
        .on("mouseout", () => {
          tooltip.classed("hidden", true);
          applyThemeFilter();
        });

      function applyThemeFilter() {
        pGroup
          .attr("opacity", (d: PaperNode) => activeThemes.has(d.theme) ? 1 : 0)
          .attr("pointer-events", (d: PaperNode) => activeThemes.has(d.theme) ? "all" : "none");
        pLabels.attr("opacity", (d: PaperNode) => showLabels && activeThemes.has(d.theme) ? 0.8 : 0);
        cDots.attr("opacity", showConcepts ? 0.5 : 0).attr("pointer-events", showConcepts ? "all" : "none");
        cLabels.attr("opacity", showConcepts ? 0.6 : 0);
        plGroup.attr("stroke-opacity", (d: PaperLink) => {
          const src = visPaperById.get(linkId(d.source));
          const tgt = visPaperById.get(linkId(d.target));
          return (src && activeThemes.has(src.theme) && tgt && activeThemes.has(tgt.theme)) ? linkOpacity : 0;
        });
      }
      applyThemeFilter();
      currentApplyThemeFilter = applyThemeFilter;

      // Reset zoom to center
      const transform = zoomIdentity.translate(0, 0).scale(1);
      currentZoomTransform = transform;
      svg.call(zoomBehavior.transform as any, transform);
    }

    function updateCenterLabel() {
      const cp = paperNodeById.get(centerPaperId);
      const label = document.getElementById("center-label")!;
      label.textContent = cp ? cp.title : centerPaperId;
      label.title = cp ? `${cp.title} (${centerPaperId})` : centerPaperId;
      document.getElementById("reset-center")!.classList.remove("hidden");
    }

    function openPaperPanel(d: PaperNode) {
      panelHeader.textContent = "Paper Concepts";
      panelTitle.textContent = d.title;
      panelTheme.textContent = d.theme;
      panelTheme.style.color = themeColors[d.theme] || "#6b7280";

      let html = "";
      if (d.authors.length > 0) {
        html += `<p class="text-xs text-gray-500 mb-3">${d.authors.join(", ")}</p>`;
      }
      if (d.concepts.length === 0) {
        html += '<p class="text-sm text-gray-400 italic">No concepts extracted yet.</p>';
      } else {
        html += '<div class="flex flex-wrap gap-1.5 mb-4">';
        for (const c of d.concepts) {
          const cat = conceptToCategory[c] || "Other";
          const colors = categoryColorMap[cat] || categoryColorMap["Other"];
          html += `<span class="inline-block text-xs px-2 py-1 rounded-full border" style="background:${colors.bg};border-color:${colors.border};color:${colors.text}">${c}</span>`;
        }
        html += "</div>";
      }

      // Show ALL connections for this paper (not just visible ones)
      const connections = filteredLinks.filter((l) => l.source === d.id || l.target === d.id);
      if (connections.length > 0) {
        html += '<div class="border-t border-gray-100 pt-3"><p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Connected Papers</p>';
        for (const link of connections) {
          const otherId = link.source === d.id ? link.target : link.source;
          const other = paperNodeById.get(otherId);
          if (other) {
            html += `<div class="mb-2 flex items-start justify-between gap-2">`;
            // Compute shared concepts on-demand
            const shared = d.concepts.filter((c: string) => other.concepts.includes(c));
            html += `<div><p class="text-xs font-medium text-gray-700">${other.title}</p><p class="text-xs text-gray-400">score: ${link.score.toFixed(1)} · ${shared.slice(0, 3).join(", ")}${shared.length > 3 ? " ..." : ""}</p></div>`;
            html += `<button data-recenter="${other.id}" class="shrink-0 text-xs text-[#663399] hover:text-[#663399]/70 font-medium" title="Center on this paper">&#8982;</button>`;
            html += `</div>`;
          }
        }
        html += "</div>";
      }

      html += '<div class="mt-4 pt-3 border-t border-gray-100 flex flex-wrap gap-3">';
      if (d.url) {
        html += `<a href="${d.url}" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Read blog post &rarr;</a>`;
      }
      html += `<button data-recenter="${d.id}" class="text-sm text-[#663399] hover:text-[#663399]/70 font-medium">Center in graph &#8982;</button>`;
      html += '</div>';

      panelBody.innerHTML = html;
      setPanelOpen(true);
    }

    function openConceptPanel(name: string, papers: string[]) {
      panelHeader.textContent = "Concept";
      panelTitle.textContent = name;
      panelTheme.textContent = `Appears in ${papers.length} papers`;
      panelTheme.style.color = "#6b7280";

      let html = '<div class="space-y-1">';
      for (const pid of papers) {
        const paper = paperNodeById.get(pid);
        if (paper) {
          html += `<div class="flex items-start justify-between gap-2 p-2 rounded-lg hover:bg-gray-50"><div>`;
          html += paper.url
            ? `<a href="${paper.url}" class="text-sm font-medium text-gray-800 hover:text-blue-600">${paper.title}</a>`
            : `<p class="text-sm font-medium text-gray-800">${paper.title}</p>`;
          html += `<p class="text-xs text-gray-400">${paper.theme}</p></div>`;
          html += `<button data-recenter="${paper.id}" class="shrink-0 text-xs text-[#663399] hover:text-[#663399]/70 font-medium" title="Center on this paper">&#8982;</button></div>`;
        }
      }
      html += "</div>";
      panelBody.innerHTML = html;
      setPanelOpen(true);
    }

    // Recenter button delegation in side panel
    panelBody.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-recenter]");
      if (!btn) return;
      const paperId = (btn as HTMLElement).dataset.recenter!;
      centerPaperId = paperId;
      rebuildGraph();
      updateCenterLabel();
      const paper = paperNodeById.get(paperId);
      if (paper) openPaperPanel(paper);
    });

    // === Depth slider + number input ===
    const depthSlider = document.getElementById("depth-slider") as HTMLInputElement;
    const depthNumber = document.getElementById("depth-number") as HTMLInputElement;
    function setDepth(val: number) {
      val = Math.max(1, Math.min(3, val));
      maxDepth = val;
      depthSlider.value = String(val);
      depthNumber.value = String(val);
      rebuildGraph();
      updateCenterLabel();
    }
    depthSlider?.addEventListener("input", () => setDepth(parseInt(depthSlider.value)));
    depthNumber?.addEventListener("change", () => setDepth(parseInt(depthNumber.value)));

    // === Min shared slider + number input ===
    const minSharedSlider = document.getElementById("min-shared-slider") as HTMLInputElement;
    const minSharedNumber = document.getElementById("min-shared-number") as HTMLInputElement;
    function setMinShared(val: number) {
      val = Math.max(2, Math.min(6, val));
      minSharedThreshold = val;
      minSharedSlider.value = String(Math.round(val * 10));
      minSharedNumber.value = val.toFixed(1);
      recomputeAdjacency();
      rebuildGraph();
      updateCenterLabel();
    }
    minSharedSlider?.addEventListener("input", () => setMinShared(parseFloat(minSharedSlider.value) / 10));
    minSharedNumber?.addEventListener("change", () => setMinShared(parseFloat(minSharedNumber.value)));

    // Reset center
    document.getElementById("reset-center")!.addEventListener("click", () => {
      centerPaperId = defaultCenterId;
      rebuildGraph();
      updateCenterLabel();
    });

    // Theme toggles — fully hide non-active themes
    document.querySelectorAll(".theme-toggle").forEach((btn) => {
      btn.addEventListener("click", () => {
        const theme = (btn as HTMLElement).dataset.theme!;
        const color = (btn as HTMLElement).dataset.color!;
        if (activeThemes.has(theme)) {
          activeThemes.delete(theme);
          (btn as HTMLElement).style.background = "transparent";
          (btn as HTMLElement).style.color = color;
        } else {
          activeThemes.add(theme);
          (btn as HTMLElement).style.background = color;
          (btn as HTMLElement).style.color = "white";
        }
        if (currentApplyThemeFilter) currentApplyThemeFilter();
      });
    });

    // === Display controls ===
    function updateDisplay() {
      if (currentApplyThemeFilter) currentApplyThemeFilter();
    }

    function updateForces() {
      if (!simulation) return;
      (simulation.force("center") as any)?.strength(centerForceStrength);
      (simulation.force("charge") as any)?.strength((d: any) =>
        d.type === "paper" ? -repelStrength - 10 * paperRadius(d as PaperNode) * nodeScale : -30
      );
      (simulation.force("link") as any)?.strength(linkForceStrength).distance(linkDistance);
      (simulation.force("collide") as any)?.strength(collisionStrength).radius((d: any) =>
        d.type === "paper" ? (paperRadius(d as PaperNode) + 4) * nodeScale : 6
      );
      simulation.alpha(0.3).restart();
    }

    (document.getElementById("toggle-labels") as HTMLInputElement)?.addEventListener("change", (e) => {
      showLabels = (e.target as HTMLInputElement).checked;
      updateDisplay();
    });
    (document.getElementById("toggle-concepts") as HTMLInputElement)?.addEventListener("change", (e) => {
      showConcepts = (e.target as HTMLInputElement).checked;
      updateDisplay();
    });

    function bindSlider(id: string, valId: string, formatter: (v: number) => string, onChange: (v: number) => void) {
      const slider = document.getElementById(id) as HTMLInputElement;
      const valEl = document.getElementById(valId);
      if (!slider) return;
      slider.addEventListener("input", () => {
        const v = parseFloat(slider.value);
        if (valEl) valEl.textContent = formatter(v);
        onChange(v);
      });
    }

    bindSlider("slider-node-size", "val-node-size", (v) => (v / 100).toFixed(1), (v) => {
      nodeScale = v / 100;
      // Update node radii without full rebuild
      nodeLayer.selectAll("circle").attr("r", (d: any) => d.type === "paper" ? paperRadius(d) * nodeScale : 4);
      labelLayer.selectAll("text.paper-label").attr("dx", (d: any) => paperRadius(d) * nodeScale + 4);
      updateForces();
    });
    bindSlider("slider-link-opacity", "val-link-opacity", (v) => (v / 100).toFixed(1), (v) => {
      linkOpacity = v / 100;
      updateDisplay();
    });
    bindSlider("slider-label-size", "val-label-size", (v) => String(v), (v) => {
      labelSize = v;
      labelLayer.selectAll("text.paper-label").attr("font-size", `${labelSize}px`);
      labelLayer.selectAll("text.concept-label").attr("font-size", `${Math.max(7, labelSize - 2)}px`);
    });

    // Force sliders
    bindSlider("slider-center-force", "val-center-force", (v) => (v / 100).toFixed(2), (v) => {
      centerForceStrength = v / 100;
      updateForces();
    });
    bindSlider("slider-repel", "val-repel", (v) => String(Math.round(v)), (v) => {
      repelStrength = v;
      updateForces();
    });
    bindSlider("slider-link-force", "val-link-force", (v) => (v / 100).toFixed(1), (v) => {
      linkForceStrength = v / 100;
      updateForces();
    });
    bindSlider("slider-link-dist", "val-link-dist", (v) => String(Math.round(v)), (v) => {
      linkDistance = v;
      updateForces();
    });
    bindSlider("slider-collision", "val-collision", (v) => (v / 100).toFixed(1), (v) => {
      collisionStrength = v / 100;
      updateForces();
    });

    // === Paper search (searches ALL papers, not just visible) ===
    const searchInput = document.getElementById("paper-search") as HTMLInputElement;
    const searchResultsEl = document.getElementById("search-results")!;

    searchInput?.addEventListener("input", () => {
      const query = searchInput.value.trim().toLowerCase();
      if (query.length < 2) { searchResultsEl.classList.add("hidden"); return; }

      const matches = allPaperNodes
        .filter((p) =>
          p.title.toLowerCase().includes(query) ||
          p.id.toLowerCase().includes(query) ||
          p.authors.some((a) => a.toLowerCase().includes(query))
        ).slice(0, 8);

      if (matches.length === 0) {
        searchResultsEl.innerHTML = '<div class="px-4 py-3 text-sm text-gray-400">No papers found</div>';
      } else {
        searchResultsEl.innerHTML = matches.map((p) =>
          `<button class="search-result w-full text-left px-4 py-2 text-sm hover:bg-gray-50 border-b border-gray-100 last:border-b-0" data-paper-id="${p.id}">
            <div class="font-medium text-gray-800 truncate">${p.title}</div>
            <div class="text-xs text-gray-400">${p.authors.length > 0 ? p.authors.slice(0, 3).join(", ") + (p.authors.length > 3 ? " ..." : "") + " &middot; " : ""}${p.id} &middot; ${p.theme}</div>
          </button>`
        ).join("");
      }
      searchResultsEl.classList.remove("hidden");

      searchResultsEl.querySelectorAll(".search-result").forEach((btn) => {
        btn.addEventListener("click", () => {
          const paperId = (btn as HTMLElement).dataset.paperId!;
          centerPaperId = paperId;
          rebuildGraph();
          updateCenterLabel();
          const paper = paperNodeById.get(paperId);
          if (paper) openPaperPanel(paper);
          searchResultsEl.classList.add("hidden");
          searchInput.value = "";
        });
      });
    });

    document.addEventListener("click", (e) => {
      if (!searchInput?.contains(e.target as Node) && !searchResultsEl?.contains(e.target as Node)) {
        searchResultsEl?.classList.add("hidden");
      }
    });

    // === Concept index tag clicks ===
    document.querySelectorAll(".concept-tag").forEach((btn) => {
      btn.addEventListener("click", () => {
        const conceptName = (btn as HTMLElement).dataset.concept!;
        const papers: string[] = JSON.parse((btn as HTMLElement).dataset.papers!);

        // Find a paper with this concept that has the most connections, center on it
        let bestPaper = papers[0];
        let bestS = 0;
        for (const pid of papers) {
          const s = connectivityScore[pid] || 0;
          if (s > bestS) { bestS = s; bestPaper = pid; }
        }
        centerPaperId = bestPaper;
        // Increase depth enough to hopefully show all papers with this concept
        const origDepth = maxDepth;
        setDepth(Math.max(maxDepth, 3));
        rebuildGraph();
        updateCenterLabel();

        openConceptPanel(conceptName, papers);

        document.querySelectorAll(".concept-tag").forEach((t) => {
          (t as HTMLElement).style.fontWeight = "normal";
        });
        (btn as HTMLElement).style.fontWeight = "bold";
      });
    });

    // === Initial render ===
    rebuildGraph();
    updateCenterLabel();
  });
</script>
