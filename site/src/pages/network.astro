---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";

// Simple taxonomy YAML parser (avoids js-yaml dependency)
function parseTaxonomy(text: string): Record<string, string[]> {
  const result: Record<string, string[]> = {};
  let currentCat = "";
  for (const line of text.split("\n")) {
    const t = line.trim();
    if (!t || t.startsWith("#") || t === "categories:") continue;
    if (!line.startsWith("    ") && t.endsWith(":")) {
      currentCat = t.slice(0, -1);
      result[currentCat] = [];
    } else if (line.startsWith("    ") && t.startsWith("- ") && currentCat) {
      result[currentCat].push(t.slice(2));
    }
  }
  return result;
}

// Load taxonomy
const taxonomyPath = path.join(process.cwd(), "../pipeline/concepts_taxonomy.yaml");
let taxonomyCategories: Record<string, string[]> = {};
try {
  taxonomyCategories = parseTaxonomy(fs.readFileSync(taxonomyPath, "utf-8"));
} catch {}

// Concept -> category lookup
const conceptToCategory: Record<string, string> = {};
for (const [cat, concepts] of Object.entries(taxonomyCategories)) {
  for (const c of concepts) conceptToCategory[c] = cat;
}

// Category color definitions
const categoryColorMap: Record<string, { bg: string; border: string; text: string; header: string }> = {
  "Representation & Manifold Learning": { bg: "#dbeafe", border: "#93c5fd", text: "#1e40af", header: "#3b82f6" },
  "Generative Models": { bg: "#e0e7ff", border: "#a5b4fc", text: "#3730a3", header: "#6366f1" },
  "Uncertainty Quantification & Robust AI": { bg: "#fce7f3", border: "#f9a8d4", text: "#9d174d", header: "#ec4899" },
  "Physics-Motivated Optimization": { bg: "#ccfbf1", border: "#5eead4", text: "#115e59", header: "#14b8a6" },
  "Reinforcement Learning & Search": { bg: "#ffedd5", border: "#fdba74", text: "#9a3412", header: "#f97316" },
  "Neural Architectures": { bg: "#cffafe", border: "#67e8f9", text: "#155e75", header: "#0891b2" },
  "Statistical & Mathematical Methods": { bg: "#f3e8ff", border: "#d8b4fe", text: "#6b21a8", header: "#a855f7" },
  "Training & Optimization": { bg: "#ecfccb", border: "#bef264", text: "#3f6212", header: "#65a30d" },
  "Particle & High-Energy Physics": { bg: "#fee2e2", border: "#fca5a5", text: "#991b1b", header: "#ef4444" },
  "Quantum Field Theory & Formal Theory": { bg: "#ede9fe", border: "#c4b5fd", text: "#5b21b6", header: "#7c3aed" },
  "Quantum Computing & Information": { bg: "#fae8ff", border: "#e879f9", text: "#86198f", header: "#d946ef" },
  "Astrophysics & Cosmology": { bg: "#d1fae5", border: "#6ee7b7", text: "#065f46", header: "#10b981" },
  "Condensed Matter & Materials": { bg: "#fef3c7", border: "#fcd34d", text: "#92400e", header: "#f59e0b" },
  "Scientific Discovery": { bg: "#dcfce7", border: "#86efac", text: "#166534", header: "#16a34a" },
};
const defaultColor = { bg: "#f3f4f6", border: "#d1d5db", text: "#4b5563", header: "#6b7280" };

// Load approved concepts from exported JSON
let conceptEntries: any[] = [];
const conceptsPath = path.join(process.cwd(), "src/data/concepts.json");
try {
  conceptEntries = JSON.parse(fs.readFileSync(conceptsPath, "utf-8"));
} catch {}

const posts = await getCollection("posts");

// Build unified paper set
const paperMap = new Map<string, { id: string; title: string; nickname: string | null; theme: string; concepts: string[]; authors: string[]; url: string | null }>();
for (const entry of conceptEntries) {
  paperMap.set(entry.arxivId, {
    id: entry.arxivId,
    title: entry.title,
    nickname: entry.nickname || null,
    theme: entry.theme,
    concepts: entry.concepts || [],
    authors: entry.authors || [],
    url: entry.blogSlug ? import.meta.env.BASE_URL + "posts/" + entry.blogSlug : null,
  });
}
for (const post of posts) {
  if (!paperMap.has(post.data.arxivId)) {
    paperMap.set(post.data.arxivId, {
      id: post.data.arxivId,
      title: post.data.title,
      nickname: null,
      theme: post.data.theme,
      concepts: post.data.concepts || [],
      authors: post.data.authors || [],
      url: import.meta.env.BASE_URL + "posts/" + post.id,
    });
  } else {
    // Merge authors from blog post if concepts.json didn't have them
    const existing = paperMap.get(post.data.arxivId)!;
    if (existing.authors.length === 0 && post.data.authors?.length > 0) {
      existing.authors = post.data.authors;
    }
  }
}

const allPapers = Array.from(paperMap.values());

const paperNodes = allPapers.map((p) => ({
  id: p.id, type: "paper" as const, title: p.title, nickname: p.nickname, theme: p.theme, concepts: p.concepts, authors: p.authors, url: p.url,
}));

const conceptUsage: Record<string, string[]> = {};
for (const p of allPapers) {
  for (const c of p.concepts) {
    if (!conceptUsage[c]) conceptUsage[c] = [];
    conceptUsage[c].push(p.id);
  }
}

const sharedConcepts = Object.entries(conceptUsage)
  .filter(([_, papers]) => papers.length >= 2)
  .map(([name, papers]) => ({ name, papers }));

const conceptNodes = sharedConcepts.map((c) => ({
  id: `concept:${c.name}`, type: "concept" as const, title: c.name, papers: c.papers,
}));

const links: { source: string; target: string }[] = [];
for (const c of sharedConcepts) {
  for (const paperId of c.papers) {
    links.push({ source: paperId, target: `concept:${c.name}` });
  }
}

// Build relevance lookup: paper -> concept -> relevance score
const relevanceMap: Record<string, Record<string, number>> = {};
for (const entry of conceptEntries) {
  relevanceMap[entry.arxivId] = {};
  for (const cd of (entry.conceptDetails || [])) {
    relevanceMap[entry.arxivId][cd.name] = cd.relevance || 0;
  }
}

// Build paper-paper links with weighted connection scores
// Score = sum of (relevance_a * relevance_b) for each shared concept
const paperLinks: { source: string; target: string; score: number; sharedConcepts: string[] }[] = [];
for (let i = 0; i < allPapers.length; i++) {
  for (let j = i + 1; j < allPapers.length; j++) {
    const shared = allPapers[i].concepts.filter((c: string) => allPapers[j].concepts.includes(c));
    if (shared.length < 2) continue;
    let score = 0;
    for (const c of shared) {
      const ra = relevanceMap[allPapers[i].id]?.[c] ?? 0;
      const rb = relevanceMap[allPapers[j].id]?.[c] ?? 0;
      score += ra * rb;
    }
    if (score >= 2) { // Only include pairs with meaningful weighted connection
      paperLinks.push({
        source: allPapers[i].id, target: allPapers[j].id,
        score: Math.round(score * 100) / 100, sharedConcepts: shared,
      });
    }
  }
}

const conceptIndex = Object.entries(conceptUsage)
  .sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]))
  .map(([name, papers]) => ({ name, count: papers.length, papers }));

// Group concepts by taxonomy category
const conceptsByCategory: Record<string, typeof conceptIndex> = {};
for (const entry of conceptIndex) {
  const cat = conceptToCategory[entry.name] || "Other";
  if (!conceptsByCategory[cat]) conceptsByCategory[cat] = [];
  conceptsByCategory[cat].push(entry);
}
const sortedCategories = [
  ...Object.keys(taxonomyCategories).filter((c) => conceptsByCategory[c]),
  ...(conceptsByCategory["Other"] ? ["Other"] : []),
];

// Strip sharedConcepts from paperLinks for the client payload (saves ~MB)
// Strip sharedConcepts from paperLinks; drop conceptNodes/links (rebuilt client-side)
const paperLinksSlim = paperLinks.map(({ source, target, score }) => ({ source, target, score }));
const graphData = JSON.stringify({
  paperNodes, paperLinks: paperLinksSlim, conceptIndex,
  conceptToCategory, categoryColorMap: { ...categoryColorMap, Other: defaultColor },
});
---

<BaseLayout title="Concept Network - IAIFI Research Blog">
