              <svg class="section-chevron w-3 h-3 text-white/40 transition-transform" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
            </button>
            <div id="section-display" class="px-3 pb-3 space-y-2">
              <label class="flex items-center justify-between cursor-pointer">
                <span class="text-white/70">Show labels</span>
                <input id="toggle-labels" type="checkbox" class="accent-[#663399] w-3.5 h-3.5" />
              </label>
              <label class="flex items-center justify-between cursor-pointer">
                <span class="text-white/70">Show concepts</span>
                <input id="toggle-concepts" type="checkbox" class="accent-[#663399] w-3.5 h-3.5" />
              </label>
              <div class="flex items-center justify-between">
                <span class="text-white/70">Node size</span>
                <div class="flex items-center gap-1">
                  <input id="slider-node-size" type="range" min="30" max="200" value="100" class="w-16 accent-[#663399] h-1" />
                  <span id="val-node-size" class="text-white/50 w-7 text-right font-mono">1.0</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-white/70">Link opacity</span>
                <div class="flex items-center gap-1">
                  <input id="slider-link-opacity" type="range" min="0" max="100" value="60" class="w-16 accent-[#663399] h-1" />
                  <span id="val-link-opacity" class="text-white/50 w-7 text-right font-mono">0.6</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-white/70">Label size</span>
                <div class="flex items-center gap-1">
                  <input id="slider-label-size" type="range" min="6" max="18" value="9" class="w-16 accent-[#663399] h-1" />
                  <span id="val-label-size" class="text-white/50 w-7 text-right font-mono">9</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Forces -->
          <div>
            <button class="settings-section-toggle w-full flex items-center justify-between px-3 py-2 hover:bg-white/5" data-section="forces">
              <span class="font-semibold text-white/80 uppercase tracking-wider text-[10px]">Forces</span>
              <svg class="section-chevron w-3 h-3 text-white/40 transition-transform" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
            </button>
            <div id="section-forces" class="px-3 pb-3 space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-white/70">Center force</span>
                <div class="flex items-center gap-1">
                  <input id="slider-center-force" type="range" min="0" max="20" value="5" class="w-16 accent-[#663399] h-1" />
                  <span id="val-center-force" class="text-white/50 w-7 text-right font-mono">0.05</span>
                </div>
              </div>
