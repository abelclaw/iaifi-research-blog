          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="8" r="2.5"/>
            <path d="M13.5 8a5.5 5.5 0 01-.3 1.8l1.3.8-1 1.7-1.3-.7a5.5 5.5 0 01-1.5 1l.1 1.5h-2l.1-1.5a5.5 5.5 0 01-1.5-1l-1.3.7-1-1.7 1.3-.8A5.5 5.5 0 012.5 8a5.5 5.5 0 01.3-1.8L1.5 5.4l1-1.7 1.3.7a5.5 5.5 0 011.5-1L5.2 1.9h2l-.1 1.5a5.5 5.5 0 011.5 1l1.3-.7 1 1.7-1.3.8a5.5 5.5 0 01.3 1.8z"/>
          </svg>
        </button>

        <!-- Settings panel -->
        <div id="settings-panel" class="hidden absolute top-12 right-3 z-30 w-60 bg-[#1e1e2e]/95 backdrop-blur-sm rounded-lg shadow-xl border border-gray-700/50 text-white text-xs overflow-hidden max-h-[calc(100%-60px)] overflow-y-auto">

          <!-- Filters -->
          <div class="border-b border-white/10">
            <button class="settings-section-toggle w-full flex items-center justify-between px-3 py-2 hover:bg-white/5" data-section="filters">
